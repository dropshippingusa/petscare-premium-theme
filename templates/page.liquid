{%- if page.handle == 'terms-of-service' -%}
  {%- render 'policy-terms-of-service' -%}
{%- elsif page.handle == 'privacy-policy' -%}
  {%- render 'policy-privacy-policy' -%}
{%- elsif page.handle == 'shipping-returns' -%}
  {%- render 'policy-shipping-returns' -%}
{%- elsif page.handle == 'legal-protection' -%}
  {%- render 'policy-legal-protection' -%}
{%- elsif page.handle == 'compliance' -%}
  {%- render 'policy-compliance' -%}
{%- elsif page.handle == 'supplier-transparency' -%}
  {%- render 'policy-supplier-transparency' -%}
{%- elsif page.handle == 'deals' -%}
  {%- render 'page-deals' -%}
{%- else -%}
  <div class="page-standard section container">
    <h1 class="section-title" style="text-align:center; margin-bottom:40px;">{{ page.title }}</h1>
    <div class="page-content" style="max-width:800px; margin:0 auto;">
      {{ page.content }}
    </div>
  </div>
{%- endif -%}
