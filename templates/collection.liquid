<div class="container section">
  <div class="collection-page-layout">
    <!-- 1. Left Sidebar Filters -->
    <aside class="collection-sidebar" id="collection-sidebar">
      <div class="sidebar-header">
        <h3>Filters</h3>
        <button class="sidebar-close-btn" id="filter-close-btn" onclick="toggleSidebarFilter()">&times;</button>
      </div>
      
      <!-- Dynamic Shopify Collection Filters -->
      <form class="filter-form" id="collection-filter-form">
        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <h4>{{ filter.label }}</h4>
            
            {%- case filter.type -%}
              {%- when 'list' -%}
                <ul>
                  {%- for value in filter.values -%}
                    <li>
                      <label>
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} onchange="ajaxFilterCollection()" />
                        {{ value.label }} ({{ value.count }})
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- when 'price_range' -%}
                <div class="price-range-inputs">
                  <input type="number" name="{{ filter.min_value.param_name }}" placeholder="Min Price" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}" onchange="ajaxFilterCollection()" />
                  <input type="number" name="{{ filter.max_value.param_name }}" placeholder="Max Price" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}" onchange="ajaxFilterCollection()" />
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </form>
    </aside>

    <!-- 2. Right Side Products Grid -->
    <div class="collection-main">
      <div class="collection-toolbar">
        <div class="collection-product-count">
          <h2>{{ collection.title }}</h2>
          <p><span id="ajax-product-count">{{ collection.products_count }}</span> Products</p>
        </div>
        
        <button class="btn btn-card-add mobile-filter-trigger-btn" onclick="toggleSidebarFilter()" style="display:none; padding:8px 16px;">🔍 Filters</button>

        <div class="collection-sorting">
          <label for="sort-by">Sort:</label>
          <select id="sort-by" onchange="ajaxFilterCollection()">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <!-- AJAX Products Container -->
      <div class="products-grid" id="collection-product-grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% else %}
          <p class="no-products-msg">No products match your active filters.</p>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
