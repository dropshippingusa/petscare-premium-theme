{%- liquid
  assign msg_1 = section.settings.announcement_1 | default: '🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout'
  assign msg_2 = section.settings.announcement_2 | default: 'Free shipping on orders $99+'
  assign msg_3 = section.settings.announcement_3 | default: 'Secure Checkout: Shop with confidence'
  assign msg_4 = section.settings.announcement_4 | default: 'Fast US Shipping: Formulated & Packaged in the USA'
  assign msg_5 = section.settings.announcement_5 | default: 'Hassle-Free Returns: Shop Risk-Free'
-%}

<div class="site-header-wrapper" id="site-header-wrapper">
<div class="announcement-bar" id="announcement-bar-ticker" role="region" aria-label="Announcements">
  <div class="announcement-bar__ticker">
    <div class="announcement-slide is-active" role="group" aria-label="1 of 5">{{ msg_1 }}</div>
    <div class="announcement-slide" role="group" aria-label="2 of 5" style="display: none;">{{ msg_2 }}</div>
    <div class="announcement-slide" role="group" aria-label="3 of 5" style="display: none;">{{ msg_3 }}</div>
    <div class="announcement-slide" role="group" aria-label="4 of 5" style="display: none;">{{ msg_4 }}</div>
    <div class="announcement-slide" role="group" aria-label="5 of 5" style="display: none;">{{ msg_5 }}</div>
  </div>
</div>

<header class="site-header" role="banner">

  <!-- ═══ TOP ROW: Logo | Search | Actions (Location/Login/Wishlist/Cart) ═══ -->
  <div class="header-container">

    <!-- Logo -->
    <a href="/" class="header-logo-container" aria-label="{{ shop.name }} — Home">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--default">
      <img src="{{ 'logo-sticky.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--sticky" style="display: none;">
    </a>

    <!-- Search Bar with Live Autocomplete -->
    <div class="header-search-wrap" id="header-search-wrap">
      <form action="/search" method="get" class="header-search-form" role="search" autocomplete="off">
        <span class="header-search-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="text"
          name="q"
          id="header-search-input"
          placeholder="Search for Products, Brands and More"
          class="header-search-input"
          aria-label="Search store"
          aria-autocomplete="list"
          aria-controls="search-autocomplete"
          aria-expanded="false"
        >
      </form>
      <!-- Live search dropdown -->
      <div class="search-autocomplete" id="search-autocomplete" role="listbox" hidden>
        <div class="search-autocomplete__inner" id="search-autocomplete-inner"></div>
      </div>
    </div>

    <!-- ★ LOCKED ACTIONS — Never move, never hide ★ -->
    <div class="header-actions">

      <!-- Search Button (Mobile Only) -->
      <button type="button" class="header-action-link header-search-toggle-btn" id="mobile-search-toggle" aria-label="Toggle search bar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>

      <!-- Location: auto-detect + manual popup -->
      <div class="loc-wrap" id="loc-wrap">
        <button type="button" class="header-action-link header-location-icon-btn" id="header-loc-btn"
          title="Change delivery location" aria-label="Change delivery location" aria-expanded="false" aria-haspopup="dialog">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="loc-zip-display" id="loc-zip-display">...</span>
        </button>

        <!-- Location Popup -->
        <div class="loc-popup" id="loc-popup" hidden role="dialog" aria-modal="true" aria-label="Delivery location">
          <div class="loc-popup__header">
            <div class="loc-popup__title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Delivery Location
            </div>
            <button type="button" class="loc-popup__close" id="loc-popup-close" aria-label="Close">&#10005;</button>
          </div>
          <p class="loc-popup__subtitle">Enter your ZIP to see delivery dates &amp; shipping options</p>
          <div class="loc-popup__input-row">
            <input type="text" id="loc-zip-input" class="loc-popup__input"
              maxlength="5" placeholder="Enter ZIP code" pattern="[0-9]{5}"
              inputmode="numeric" autocomplete="postal-code" aria-label="ZIP code">
            <button type="button" class="loc-popup__confirm" id="loc-zip-confirm">Update</button>
          </div>
          <button type="button" class="loc-popup__gps-btn" id="loc-gps-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/><path d="M12 2a10 10 0 100 20A10 10 0 0012 2z" stroke-dasharray="2 4"/></svg>
            Use My Current Location
          </button>
          <div class="loc-popup__status" id="loc-popup-status"></div>
        </div>
      </div>

      <!-- Login / Account -->
      {%- if customer -%}
        <a href="/account" class="header-action-link header-account-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Account</span>
        </a>
      {%- else -%}
        <a href="/account/login" class="header-action-link header-account-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Login</span>
        </a>
      {%- endif -%}

      <!-- Wishlist -->
      <a href="/pages/wishlist" class="header-action-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span>Wishlist</span>
      </a>

      <!-- Cart -->
      <button type="button" class="header-action-link header-cart-btn" data-open-cart>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span>Cart</span>
        <span class="cart-count-badge" id="header-cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>

    </div>
  </div>

  <!-- ═══ NAV ROW: constrained to theme width, See More always visible ═══ -->
  <div class="header-nav-row">
    <nav class="header-nav" aria-label="Main navigation">

      <!-- Home -->
      <a href="/" class="header-nav__link{% if request.path == '/' %} is-active{% endif %}">Home</a>

      <!-- Top Picks — highlighted, pinned right after Home -->
      <!-- Top Picks — highlighted, pinned right after Home -->
      {%- assign top_picks_url = '/collections/all' -%}
      {%- for coll in collections -%}
        {%- if coll.title == 'Top Picks' -%}
          {%- assign top_picks_url = coll.url -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      <a href="{{ top_picks_url }}" class="header-nav__link header-nav__link--hot header-nav__coll-link{% if request.path == top_picks_url %} is-active{% endif %}">
        Top Picks <span class="nav-hot-badge">🔥</span>
      </a>

      <!-- All Products -->
      <a href="/collections/all" class="header-nav__link{% if request.path == '/collections/all' %} is-active{% endif %}">All Products</a>

      <!-- ALL collections rendered (limit:50 to show more than default 20) -->
      <!-- JS hides overflow ones into See More dropdown -->
      {%- for collection in collections limit: 50 -%}
        {%- unless collection.handle == 'frontpage'
          or collection.handle == 'all'
          or collection.handle == 'dogs'
          or collection.handle == 'cats'
          or collection.handle == 'top-picks'
          or collection.title == 'Top Picks' -%}
          <a href="{{ collection.url }}" class="header-nav__link header-nav__coll-link{% if request.path == collection.url %} is-active{% endif %}">{{ collection.title }}</a>
        {%- endunless -%}
      {%- endfor -%}

      <!-- See More: hidden by default — only shown by JS when items overflow -->
      <div class="header-nav__more-wrap" id="nav-more-wrap" style="display:none">
        <button type="button" class="header-nav__link header-nav__see-more-btn" id="nav-see-more-btn" aria-expanded="false" aria-haspopup="listbox">
          See More <span class="see-more-chevron">▾</span>
        </button>
        <div class="header-nav__more-dropdown" id="nav-see-more-dropdown" hidden role="listbox">
          <!-- overflow links injected here by JS -->
        </div>
      </div>

    </nav>
  </div>

</header>
</div>

<script>
(function() {
  function initNavOverflow() {
    var nav      = document.querySelector('.header-nav');
    var wrap     = document.getElementById('nav-more-wrap');
    var btn      = document.getElementById('nav-see-more-btn');
    var dropdown = document.getElementById('nav-see-more-dropdown');
    if (!nav || !btn || !dropdown || !wrap) return;

    // All collection links (candidates for overflow)
    var collLinks = Array.from(nav.querySelectorAll('.header-nav__coll-link'));
    var overflowLinks = [];

    function compute() {
      // 1. Reset: show all collection links, clear dropdown, hide See More
      collLinks.forEach(function(el) { el.hidden = false; });
      dropdown.innerHTML = '';
      dropdown.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.querySelector('.see-more-chevron').textContent = '\u25BE';
      overflowLinks = [];
      wrap.style.display = 'none'; // hide See More so nav measures without it

      // 2. If nav already fits with all items visible — done, no See More needed
      if (nav.scrollWidth <= nav.clientWidth) return;

      // 3. Nav overflows — show See More button so its width is included in measurement
      wrap.style.display = '';

      // 4. Hide collection links from the right one-by-one until nav fits
      for (var i = collLinks.length - 1; i >= 0; i--) {
        if (nav.scrollWidth <= nav.clientWidth) break;
        collLinks[i].hidden = true;
        overflowLinks.unshift(collLinks[i]);
      }

      // 5. Build dropdown links from overflow items
      overflowLinks.forEach(function(el) {
        var a = document.createElement('a');
        a.href = el.href;
        a.textContent = el.textContent.trim();
        a.className = 'header-nav__more-drop-item';
        dropdown.appendChild(a);
      });

      // 6. If nothing ended up overflowing after showing See More, hide it again
      if (overflowLinks.length === 0) {
        wrap.style.display = 'none';
      }
    }

    // Toggle dropdown on See More click
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (overflowLinks.length === 0) return;
      var isOpen = !dropdown.hidden;
      dropdown.hidden = isOpen;
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      btn.querySelector('.see-more-chevron').textContent = isOpen ? '\u25BE' : '\u25B4';
    });

    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      if (!wrap.contains(e.target)) {
        dropdown.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.see-more-chevron').textContent = '\u25BE';
      }
    });

    // Debounced resize — recompute whenever browser window changes
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(compute, 120);
    });

    // Run after fonts finish rendering, then again for safety
    setTimeout(compute, 80);
    setTimeout(compute, 450);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavOverflow);
  } else {
    initNavOverflow();
  }
})();
</script>

<script>
/* ── Live Search Autocomplete ─────────────────────── */
(function() {
  var input     = document.getElementById('header-search-input');
  var dropdown  = document.getElementById('search-autocomplete');
  var inner     = document.getElementById('search-autocomplete-inner');
  if (!input || !dropdown || !inner) return;

  var debounceTimer;
  var lastQuery = '';

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function showDropdown(products) {
    if (!products || products.length === 0) {
      inner.innerHTML = '<p class="search-autocomplete__empty">No products found</p>';
    } else {
      inner.innerHTML = products.map(function(p) {
        var img = p.featured_image
          ? '<img src="' + p.featured_image.url + '" alt="' + p.featured_image.alt + '" class="search-autocomplete__img" loading="lazy">'
          : '<div class="search-autocomplete__img search-autocomplete__img--placeholder"></div>';
        var price = p.price ? formatMoney(p.price) : '';
        var comparePrice = (p.compare_at_price && p.compare_at_price > p.price)
          ? '<s class="search-autocomplete__compare">' + formatMoney(p.compare_at_price) + '</s>' : '';
        return '<a href="' + p.url + '" class="search-autocomplete__item" role="option">'
          + img
          + '<span class="search-autocomplete__info">'
          +   '<span class="search-autocomplete__title">' + p.title + '</span>'
          +   '<span class="search-autocomplete__price">' + price + ' ' + comparePrice + '</span>'
          + '</span>'
          + '</a>';
      }).join('');
    }
    dropdown.hidden = false;
    input.setAttribute('aria-expanded', 'true');
  }

  function hideDropdown() {
    dropdown.hidden = true;
    input.setAttribute('aria-expanded', 'false');
    inner.innerHTML = '';
    lastQuery = '';
  }

  function fetchSuggestions(q) {
    if (q === lastQuery) return;
    lastQuery = q;
    fetch('/search/suggest.json?q=' + encodeURIComponent(q)
      + '&resources[type]=product&resources[limit]=6&resources[options][unavailable_products]=last')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var products = data.resources && data.resources.results && data.resources.results.products;
        showDropdown(products || []);
      })
      .catch(function() { hideDropdown(); });
  }

  input.addEventListener('input', function() {
    var q = this.value.trim();
    clearTimeout(debounceTimer);
    if (q.length < 3) { hideDropdown(); return; }
    debounceTimer = setTimeout(function() { fetchSuggestions(q); }, 250);
  });

  // Close on Escape
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { hideDropdown(); this.blur(); }
  });

  // Close when clicking outside
  document.addEventListener('click', function(e) {
    if (!document.getElementById('header-search-wrap').contains(e.target)) {
      hideDropdown();
    }
  });
})();
</script>

<script>
/* ── Mobile Search Toggle ─────────────────────────── */
(function() {
  var toggleBtn = document.getElementById('mobile-search-toggle');
  var searchWrap = document.getElementById('header-search-wrap');
  if (!toggleBtn || !searchWrap) return;

  toggleBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    var isOpen = searchWrap.classList.toggle('is-open');
    if (isOpen) {
      var input = searchWrap.querySelector('input');
      if (input) {
        input.focus();
        if (input.value.trim().length >= 3) {
          input.dispatchEvent(new Event('input'));
        }
      }
    }
  });
})();
</script>

<script>
/* ── Location: Auto-detect + Manual Popup (Option C) ─ */
(function() {
  var STORAGE_KEY = 'petscare_zip';
  var DEFAULT_ZIP = '—';

  var btn        = document.getElementById('header-loc-btn');
  var popup      = document.getElementById('loc-popup');
  var closeBtn   = document.getElementById('loc-popup-close');
  var zipDisplay = document.getElementById('loc-zip-display');
  var zipInput   = document.getElementById('loc-zip-input');
  var confirmBtn = document.getElementById('loc-zip-confirm');
  var gpsBtn     = document.getElementById('loc-gps-btn');
  var statusEl   = document.getElementById('loc-popup-status');
  if (!btn || !popup) return;

  /* ─── Helpers ─── */
  function setZip(zip, save) {
    if (!zip) return;
    zip = zip.toString().trim().substring(0, 5);
    if (zipDisplay) zipDisplay.textContent = zip;
    // Update any other zip spans on the page (e.g. PDP delivery estimates)
    document.querySelectorAll('.loc-zip-inline, .loc-zip-display').forEach(function(el) {
      el.textContent = zip;
    });
    if (save) {
      try { localStorage.setItem(STORAGE_KEY, zip); } catch(e) {}
    }
  }

  function setStatus(msg, type) {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.className = 'loc-popup__status' + (type ? ' loc-status--' + type : '');
  }

  function openPopup() {
    popup.hidden = false;
    btn.setAttribute('aria-expanded', 'true');
    setStatus('');
    var saved = '';
    try { saved = localStorage.getItem(STORAGE_KEY) || ''; } catch(e) {}
    if (zipInput) {
      zipInput.value = saved;
      setTimeout(function() { zipInput.focus(); zipInput.select(); }, 80);
    }
  }

  function closePopup() {
    popup.hidden = true;
    btn.setAttribute('aria-expanded', 'false');
    setStatus('');
  }

  /* ─── Auto-detect by IP on first visit (silent, no permission) ─── */
  function autoDetectByIP() {
    try {
      var saved = localStorage.getItem(STORAGE_KEY);
      if (saved && saved.length === 5) {
        setZip(saved, false);
        return; // already have a zip, done
      }
    } catch(e) {}
    // Silently fetch ZIP from IP
    fetch('https://ipapi.co/json/', { mode: 'cors' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var zip = d.postal || d.zip || '';
        if (zip && /^[0-9]{5}$/.test(zip)) {
          setZip(zip, true);
        } else {
          setZip(DEFAULT_ZIP, false);
        }
      })
      .catch(function() {
        setZip(DEFAULT_ZIP, false);
      });
  }

  /* ─── GPS detect ─── */
  function detectByGPS() {
    if (!navigator.geolocation) {
      setStatus('GPS not supported. Enter ZIP manually.', 'error');
      return;
    }
    if (gpsBtn) gpsBtn.disabled = true;
    setStatus('Detecting your location...', 'loading');
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        var lat = pos.coords.latitude;
        var lon = pos.coords.longitude;
        fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lon, {
          headers: { 'Accept-Language': 'en', 'User-Agent': 'PetsCareUSA/1.0' }
        })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var zip = (d.address && (d.address.postcode || d.address.postal_code)) || '';
            zip = zip.replace(/[^0-9]/g, '').substring(0, 5);
            if (zip.length === 5) {
              setZip(zip, true);
              if (zipInput) zipInput.value = zip;
              setStatus('\u2713 Location detected: ' + zip, 'success');
              setTimeout(closePopup, 1400);
            } else {
              setStatus('Could not get ZIP. Enter manually below.', 'error');
            }
            if (gpsBtn) gpsBtn.disabled = false;
          })
          .catch(function() {
            setStatus('Detection failed. Enter ZIP manually.', 'error');
            if (gpsBtn) gpsBtn.disabled = false;
          });
      },
      function(err) {
        var msg = err.code === 1
          ? 'Location access denied. Enter ZIP manually.'
          : 'Could not get location. Enter ZIP manually.';
        setStatus(msg, 'error');
        if (gpsBtn) gpsBtn.disabled = false;
      },
      { timeout: 8000 }
    );
  }

  /* ─── Confirm manual ZIP ─── */
  function confirmZip() {
    var val = (zipInput ? zipInput.value : '').replace(/[^0-9]/g, '').substring(0, 5);
    if (val.length !== 5) {
      setStatus('Please enter a valid 5-digit US ZIP code.', 'error');
      if (zipInput) zipInput.focus();
      return;
    }
    setZip(val, true);
    setStatus('\u2713 Saved! Delivering to ' + val, 'success');
    setTimeout(closePopup, 1200);
  }

  /* ─── Event listeners ─── */
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    if (popup.hidden) { openPopup(); } else { closePopup(); }
  });

  if (closeBtn) closeBtn.addEventListener('click', closePopup);
  if (confirmBtn) confirmBtn.addEventListener('click', confirmZip);
  if (gpsBtn) gpsBtn.addEventListener('click', detectByGPS);

  if (zipInput) {
    zipInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') confirmZip();
      if (e.key === 'Escape') closePopup();
    });
    // Only allow digits
    zipInput.addEventListener('input', function() {
      this.value = this.value.replace(/[^0-9]/g, '').substring(0, 5);
    });
  }

  // Close on outside click
  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('loc-wrap');
    if (wrap && !wrap.contains(e.target) && !popup.hidden) {
      closePopup();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !popup.hidden) closePopup();
  });

  /* ─── Init ─── */
  autoDetectByIP();
})();
</script>
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Ticker"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Message 1",
      "default": "🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Message 2",
      "default": "Free shipping on orders $99+"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Message 3",
      "default": "Secure Checkout: Shop with confidence"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Message 4",
      "default": "Fast US Shipping: Formulated & Packaged in the USA"
    },
    {
      "type": "text",
      "id": "announcement_5",
      "label": "Message 5",
      "default": "Hassle-Free Returns: Shop Risk-Free"
    }
  ]
}
{% endschema %}
