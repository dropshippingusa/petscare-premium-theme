<section class="shop-by-pet section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Shop by Pet</span>
      <h2 class="section-title">Happy Pets. Happy Life.</h2>
      <p class="section-desc">Select your pet type to explore tailored premium nutrition, accessories, and wellness products.</p>
    </div>

    <div class="pet-cards-grid">
      <!-- Dog Card -->
      {% assign dog_collection = collections['dogs'] %}
      <a href="{% if dog_collection != blank %}{{ dog_collection.url }}{% else %}/collections/all{% endif %}" class="pet-card card-dog">
        <div class="pet-card-bg"></div>
        <div class="pet-card-content">
          <span class="pet-card-emoji">🐕</span>
          <h3>Dogs</h3>
          <p class="pet-count">
            {% if dog_collection != blank %}
              {{ dog_collection.all_products_count }} Products
            {% else %}
              Premium Dog Supplies
            {% endif %}
          </p>
          <span class="pet-card-btn">Shop Dogs →</span>
        </div>
      </a>

      <!-- Cat Card -->
      {% assign cat_collection = collections['cats'] %}
      <a href="{% if cat_collection != blank %}{{ cat_collection.url }}{% else %}/collections/all{% endif %}" class="pet-card card-cat">
        <div class="pet-card-bg"></div>
        <div class="pet-card-content">
          <span class="pet-card-emoji">🐈</span>
          <h3>Cats</h3>
          <p class="pet-count">
            {% if cat_collection != blank %}
              {{ cat_collection.all_products_count }} Products
            {% else %}
              Premium Cat Supplies
            {% endif %}
          </p>
          <span class="pet-card-btn">Shop Cats →</span>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Pet Cards",
  "settings": []
}
{% endschema %}
