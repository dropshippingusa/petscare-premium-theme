{%- assign dogs_image = section.settings.dogs_image -%}
{%- assign cats_image = section.settings.cats_image -%}
{%- assign dogs_collection = section.settings.dogs_collection -%}
{%- assign cats_collection = section.settings.cats_collection -%}

<section class="section" id="shop-by-pet" aria-labelledby="shop-by-pet-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">Shop by Pet</span>
        <h2 class="section-title" id="shop-by-pet-title">Built for Every Pet</h2>
      </div>
    </div>

    <div class="shop-by-pet__grid">

      {%- comment -%} Dogs Card {%- endcomment -%}
      {%- assign dogs_url = dogs_collection.url | default: '/collections/all?pet=dogs' -%}
      <a href="{{ dogs_url }}" class="pet-card" aria-label="Shop dog products">
        {%- if dogs_image != blank -%}
          <img
            src="{{ dogs_image | image_url: width: 800 }}"
            srcset="{{ dogs_image | image_url: width: 500 }} 500w, {{ dogs_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 640px) 100vw, 50vw"
            alt="{{ dogs_image.alt | default: 'Shop dog products' }}"
            class="pet-card__img"
            loading="lazy"
            width="800" height="600"
          >
        {%- else -%}
          <img
            src="https://cdn.shopify.com/s/files/1/0086/0795/7054/files/CLH_for_dogs.webp?v=1742375228"
            alt="Shop dog products"
            class="pet-card__img"
            loading="lazy"
            width="800" height="600"
          >
        {%- endif -%}
        <div class="pet-card__overlay"></div>
        <div class="pet-card__content">
          <h3 class="pet-card__title">Dogs</h3>
          {%- if dogs_collection != blank -%}
            <p class="pet-card__count">{{ dogs_collection.all_products_count }} products</p>
          {%- endif -%}
          <span class="pet-card__cta">
            Shop Now
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

      {%- comment -%} Cats Card {%- endcomment -%}
      {%- assign cats_url = cats_collection.url | default: '/collections/all?pet=cats' -%}
      <a href="{{ cats_url }}" class="pet-card" aria-label="Shop cat products">
        {%- if cats_image != blank -%}
          <img
            src="{{ cats_image | image_url: width: 800 }}"
            srcset="{{ cats_image | image_url: width: 500 }} 500w, {{ cats_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 640px) 100vw, 50vw"
            alt="{{ cats_image.alt | default: 'Shop cat products' }}"
            class="pet-card__img"
            loading="lazy"
            width="800" height="600"
          >
        {%- else -%}
          <img
            src="https://cdn.shopify.com/s/files/1/0086/0795/7054/files/cat_toys_79bf694c-2c5c-4f18-8cac-626ccf76c503.webp?v=1742375228"
            alt="Shop cat products"
            class="pet-card__img"
            loading="lazy"
            width="800" height="600"
          >
        {%- endif -%}
        <div class="pet-card__overlay"></div>
        <div class="pet-card__content">
          <h3 class="pet-card__title">Cats</h3>
          {%- if cats_collection != blank -%}
            <p class="pet-card__count">{{ cats_collection.all_products_count }} products</p>
          {%- endif -%}
          <span class="pet-card__cta">
            Shop Now
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Pet",
  "settings": [
    {
      "type": "image_picker",
      "id": "dogs_image",
      "label": "Dogs card image"
    },
    {
      "type": "collection",
      "id": "dogs_collection",
      "label": "Dogs collection"
    },
    {
      "type": "image_picker",
      "id": "cats_image",
      "label": "Cats card image"
    },
    {
      "type": "collection",
      "id": "cats_collection",
      "label": "Cats collection"
    }
  ],
  "presets": [
    {
      "name": "Shop by Pet"
    }
  ]
}
{% endschema %}
