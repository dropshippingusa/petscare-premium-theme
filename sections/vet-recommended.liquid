<section class="vet-section" aria-labelledby="vet-section-title">
  <div class="vet-section__inner">

    <div class="vet-section__visual">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 500 }} 500w, {{ section.settings.image | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: 'Vet-approved products' }}"
          class="vet-section__img"
          loading="lazy"
          width="800" height="1000"
        >
      {%- else -%}
        <div style="width:100%;height:100%;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);display:flex;align-items:center;justify-content:center;">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(37,99,235,0.2)" stroke-width="0.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      {%- endif -%}

      <div class="vet-section__seal">
        <p class="vet-section__seal-num">{{ section.settings.stat_number | default: '500+' }}</p>
        <p class="vet-section__seal-text">{{ section.settings.stat_label | default: 'Vets recommend us' }}</p>
      </div>
    </div>

    <div class="vet-section__content">
      <div>
        <span class="section-label">{{ section.settings.eyebrow | default: 'Vet Recommended' }}</span>
        <h2 class="section-title" id="vet-section-title">{{ section.settings.title | default: 'Science Meets Pet Care' }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="section-sub" style="margin-top:12px">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      <ul class="vet-feature-list" role="list">
        {%- for block in section.blocks -%}
          <li class="vet-feature" {{ block.shopify_attributes }}>
            <div class="vet-feature__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'check' -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {%- when 'leaf' -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 19.47a1 1 0 001.74 1c.6-1.05 1.33-2.05 2.2-2.92C9 19.5 11 20 13 20c4 0 8-3 9-9-1 1-2 2-5 2s-5-2-5-2c3 0 5-1 5-3z"/></svg>
                {%- when 'lab' -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v9l3.5 6H5.5L9 12V3z"/><line x1="9" y1="3" x2="15" y2="3"/></svg>
                {%- when 'heart' -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                {%- else -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {%- endcase -%}
            </div>
            <div>
              <p class="vet-feature__title">{{ block.settings.title }}</p>
              <p class="vet-feature__text">{{ block.settings.text }}</p>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary">
          {{ section.settings.cta_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Vet Recommended",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section image (vet/product lifestyle photo)"
    },
    {
      "type": "text",
      "id": "stat_number",
      "label": "Floating stat number",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Floating stat label",
      "default": "Vets recommend us"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Vet Recommended"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "Science Meets Pet Care"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (optional)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop Vet-Approved Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "leaf", "label": "Natural / Leaf" },
            { "value": "lab", "label": "Science / Lab" },
            { "value": "heart", "label": "Care / Heart" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature title",
          "default": "Clinically Tested"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature description",
          "default": "Every formula is tested for safety and efficacy by licensed veterinary professionals."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vet Recommended",
      "blocks": [
        { "type": "feature", "settings": { "icon": "check", "title": "Clinically Tested", "text": "Every formula tested by licensed veterinarians for safety and efficacy." } },
        { "type": "feature", "settings": { "icon": "leaf", "title": "Natural Ingredients", "text": "No artificial fillers, preservatives, or harmful additives. Ever." } },
        { "type": "feature", "settings": { "icon": "lab", "title": "Science-Backed", "text": "Formulated using the latest peer-reviewed nutritional science." } }
      ]
    }
  ]
}
{% endschema %}
