<header class="header" id="header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <span class="logo-paw">🐾</span>
      <span class="logo-text">PetsCare<span class="logo-dot">.com</span></span>
    </a>
    
    <nav class="nav" id="main-nav">
      <ul class="nav-list">
        {% for link in linklists.main-menu.links %}
          <li><a href="{{ link.url }}" class="nav-link {% if link.active %}active{% endif %}">{{ link.title }}</a></li>
        {% else %}
          <li><a href="/" class="nav-link active">Home</a></li>
          <li><a href="/collections/all" class="nav-link">Shop</a></li>
          <li><a href="/pages/about" class="nav-link">About</a></li>
          <li><a href="/pages/contact" class="nav-link">Contact</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="icon-btn" id="search-btn" aria-label="Search">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <button class="icon-btn cart-icon-btn" id="cart-icon-trigger" aria-label="Cart">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" id="header-cart-count">{{ cart.item_count }}</span>
      </button>
      <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  
  <div class="search-overlay" id="search-overlay">
    <div class="search-inner container">
      <input type="text" class="search-input" placeholder="Search for products, brands, tags..." id="search-input" />
      <button class="search-close" id="search-close">✕</button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
