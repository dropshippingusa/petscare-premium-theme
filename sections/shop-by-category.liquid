<section class="section section--alt" aria-labelledby="categories-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">{{ section.settings.label | default: 'Browse by Category' }}</span>
        <h2 class="section-title" id="categories-title">{{ section.settings.title | default: 'Everything Your Pet Needs' }}</h2>
      </div>
    </div>

    <div class="category-grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign cat_url = block.settings.collection.url | default: block.settings.fallback_url | default: '/collections/all' -%}
        {%- assign cat_image = block.settings.image -%}
        <a href="{{ cat_url }}" class="category-card" role="listitem" {{ block.shopify_attributes }} aria-label="{{ block.settings.name }}">
          <div class="category-card__image-wrapper" aria-hidden="true">
            {%- if cat_image != blank -%}
              <img
                src="{{ cat_image | image_url: width: 240 }}"
                alt="{{ block.settings.name | escape }}"
                class="category-card__img"
                loading="lazy"
                width="120"
                height="120"
              >
            {%- else -%}
              {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/dog_bowls.webp?v=1742375228' -%}
              {%- assign name_downcase = block.settings.name | downcase -%}
              {%- if name_downcase contains 'toy' -%}
                {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/cat_toys_79bf694c-2c5c-4f18-8cac-626ccf76c503.webp?v=1742375228' -%}
              {%- elsif name_downcase contains 'walk' or name_downcase contains 'collar' or name_downcase contains 'leash' or name_downcase contains 'accessories' -%}
                {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/walkwear_5c6c2121-cb23-455b-80df-db4be934f0e9.webp?v=1742375228' -%}
              {%- elsif name_downcase contains 'chew' or name_downcase contains 'treat' or name_downcase contains 'yakies' -%}
                {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/yakies.webp?v=1742375228' -%}
              {%- elsif name_downcase contains 'litter' or name_downcase contains 'cleaning' or name_downcase contains 'grooming' -%}
                {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/cat_litter_a3ab9c21-1f9d-4762-b91c-297bc099fa71.webp?v=1742375228' -%}
              {%- elsif name_downcase contains 'food' or name_downcase contains 'broth' or name_downcase contains 'health' or name_downcase contains 'supplement' -%}
                {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/bone_broth_bbdfcfbf-78b1-4f9e-bd9d-09559c5d0124.webp?v=1742375228' -%}
              {%- endif -%}
              <img
                src="{{ fallback_img }}"
                alt="{{ block.settings.name | escape }}"
                class="category-card__img"
                loading="lazy"
                width="120"
                height="120"
              >
            {%- endif -%}
          </div>
          <span class="category-card__name">{{ block.settings.name }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Everything Your Pet Needs"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image (lifestyle or product)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Health"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to collection"
        },
        {
          "type": "url",
          "id": "fallback_url",
          "label": "Fallback URL (if no collection selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "name": "Health" } },
        { "type": "category", "settings": { "name": "Food" } },
        { "type": "category", "settings": { "name": "Treats" } },
        { "type": "category", "settings": { "name": "Dental" } },
        { "type": "category", "settings": { "name": "Travel" } },
        { "type": "category", "settings": { "name": "Beds" } },
        { "type": "category", "settings": { "name": "Cleaning" } },
        { "type": "category", "settings": { "name": "Accessories" } },
        { "type": "category", "settings": { "name": "Training" } },
        { "type": "category", "settings": { "name": "Toys" } }
      ]
    }
  ]
}
{% endschema %}
