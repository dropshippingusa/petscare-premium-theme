{%- assign hero_image = section.settings.hero_image -%}
{%- assign headline = section.settings.headline | default: 'Premium Care for the Pets You Love' -%}
{%- assign headline_highlight = section.settings.headline_highlight | default: 'Pets You Love' -%}
{%- assign subtext = section.settings.subtext | default: 'Science-backed nutrition, vet-approved supplements, and expertly curated products — made for US pet parents who demand the best.' -%}
{%- assign cta_primary_text = section.settings.cta_primary_text | default: 'Shop All Products' -%}
{%- assign cta_primary_url = section.settings.cta_primary_url | default: '/collections/all' -%}
{%- assign cta_secondary_text = section.settings.cta_secondary_text | default: 'Shop for Dogs' -%}
{%- assign cta_secondary_url = section.settings.cta_secondary_url | default: '/collections/all?pet=dogs' -%}
{%- assign badge_title = section.settings.badge_title | default: '50,000+ Happy Pets' -%}
{%- assign badge_sub = section.settings.badge_sub | default: 'Trusted by US families nationwide' -%}
{%- assign eyebrow = section.settings.eyebrow | default: 'Trusted by 50,000+ Pet Parents' -%}
{%- comment -%} HUFT Redesign style sync comment {%- endcomment -%}
<section class="hero-section" aria-label="Hero banner">
  <div class="hero hero--three-col">
    <!-- Left column: Dog Image Link -->
    <a href="{{ cta_secondary_url | default: '/collections/all?pet=dogs' }}" class="hero__visual hero__visual--left" aria-label="Shop Dogs">
      <img
        src="{{ 'hero-dog.png' | asset_url }}"
        alt="Shop Dogs"
        class="hero__img"
        loading="eager"
        width="400"
        height="400"
      >
    </a>

    <!-- Middle column: Text content -->
    <div class="hero__content hero__content--middle">
      <span class="hero__eyebrow">{{ eyebrow }}</span>

      <h1 class="hero__headline">
        {%- assign headline_parts = headline | split: headline_highlight -%}
        {{ headline_parts[0] }}<em>{{ headline_highlight }}</em>{{ headline_parts[1] }}
      </h1>

      <p class="hero__sub">{{ subtext }}</p>

      <div class="hero__actions">
        <a href="#shop-by-pet" class="btn btn--primary btn--lg" style="padding: 8px 22px; height: auto;">
          Explore Products
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="hero__trust">
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Free shipping
        </div>
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Vet-approved formulas
        </div>
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Easy Returns
        </div>
      </div>
    </div>

    <!-- Right column: Cat Image Link -->
    <a href="/collections/all?pet=cats" class="hero__visual hero__visual--right" aria-label="Shop Cats">
      {%- if hero_image != blank -%}
        <img
          src="{{ hero_image | image_url: width: 600 }}"
          alt="{{ hero_image.alt | default: 'Shop Cats' }}"
          class="hero__img"
          loading="eager"
          width="400"
          height="400"
        >
      {%- else -%}
        <img
          src="{{ 'hero-cat.png' | asset_url }}"
          alt="Shop Cats"
          class="hero__img"
          loading="eager"
          width="400"
          height="400"
        >
      {%- endif -%}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (lifestyle photography recommended)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Trusted by 50,000+ Pet Parents"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Premium Care for the Pets You Love"
    },
    {
      "type": "text",
      "id": "headline_highlight",
      "label": "Headline highlight word(s)",
      "default": "Pets You Love",
      "info": "This exact text within the headline will be colored in the brand accent color"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Science-backed nutrition, vet-approved supplements, and expertly curated products — made for US pet parents who demand the best."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA text",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Shop for Dogs"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Floating badge title",
      "default": "50,000+ Happy Pets"
    },
    {
      "type": "text",
      "id": "badge_sub",
      "label": "Floating badge subtitle",
      "default": "Trusted by US families nationwide"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
