{%- assign discount_price = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign discount_price = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
{%- endif -%}

<div class="container section">
  <!-- Breadcrumbs -->
  <nav class="breadcrumb" aria-label="breadcrumbs">
    <a href="/">Home</a>
    <span class="sep">/</span>
    <a href="/collections/all">Shop</a>
    <span class="sep">/</span>
    <span>{{ product.title }}</span>
  </nav>

  <div class="pdp-layout">
    <!-- Left Column: Gallery Slider -->
    <div class="pdp-gallery-wrap">
      <div class="pdp-main-image">
        <img id="pdp-featured-image" src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title | escape }}" />
      </div>
      
      <!-- Thumbnail swiper -->
      {% if product.images.size > 1 %}
        <div class="pdp-thumbnails">
          {% for image in product.images %}
            <button class="pdp-thumb-btn {% if forloop.first %}active{% endif %}" onclick="switchPdpImage('{{ image | img_url: '600x600', crop: 'center' }}', this)">
              <img src="{{ image | img_url: '100x100', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy" />
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Right Column: Product Operations & Purchase Form -->
    <div class="pdp-info-wrap">
      <p class="pdp-brand">{{ product.vendor }}</p>
      <h1 class="pdp-title">{{ product.title }}</h1>
      
      <!-- Ratings & Reviews -->
      <div class="pdp-rating-row">
        <span class="pdp-rating-badge">4.9 ★</span>
        <span class="pdp-rating-text">47 Customer Reviews</span>
      </div>

      <!-- Pricing Row -->
      <div class="pdp-price-row">
        <span class="pdp-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="pdp-old-price">{{ product.compare_at_price | money }}</span>
          <span class="pdp-discount-percent">{{ discount_price }}% off</span>
        {% endif %}
      </div>

      <!-- Delivery / Stock Status -->
      <div class="pdp-delivery-badge">
        <span>Arrives: <strong>Thursday, Jul 16</strong></span>
        <span class="sep">|</span>
        <span>Status: <strong style="color:#388e3c;">In Stock</strong></span>
      </div>

      <!-- Variant Selectors -->
      <div class="pdp-variants-panel">
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="variant-option-group">
              <span class="variant-label">Select {{ option.name }}:</span>
              <div class="variant-pill-row">
                {% for value in option.values %}
                  <label class="variant-pill-label">
                    <input type="radio" name="option-{{ option.position }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} class="variant-hidden-radio" onclick="updateVariantSelection()" />
                    <span class="variant-pill-box">{{ value }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}
      </div>

      <!-- Subscription Options (Flipkart/Chewy AutoShip style) -->
      <div class="pdp-purchase-options">
        <label class="pdp-option-card active">
          <input type="radio" name="purchase_type" value="onetime" checked onclick="togglePurchaseType('onetime')" />
          <div class="pdp-option-info">
            <span class="option-title">One-Time Purchase</span>
            <span class="option-desc">Buy once at retail pricing.</span>
          </div>
          <span class="option-price">{{ product.price | money }}</span>
        </label>
        
        <label class="pdp-option-card">
          <input type="radio" name="purchase_type" value="autoship" onclick="togglePurchaseType('autoship')" />
          <div class="pdp-option-info">
            <span class="option-title">🐾 Subscribe &amp; Save 10%</span>
            <span class="option-desc">Auto-delivers every 30 days. Cancel anytime.</span>
          </div>
          <span class="option-price">{{ product.price | times: 0.9 | money }}</span>
        </label>
      </div>

      <!-- Product Form / Add to Cart -->
      <form method="post" action="/cart/add" class="pdp-cart-form" onsubmit="ajaxAddToCartForm(this); return false;">
        <input type="hidden" name="id" id="pdp-selected-variant-id" value="{{ product.selected_or_first_available_variant.id }}" />
        
        <div class="pdp-qty-row">
          <label for="Quantity">Quantity:</label>
          <div class="qty-selector">
            <button type="button" onclick="adjustQty(-1)">-</button>
            <input type="number" name="quantity" id="pdp-quantity" value="1" min="1" readonly />
            <button type="button" onclick="adjustQty(1)">+</button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-pdp-add">Add to Cart</button>
      </form>
    </div>
  </div>

  <!-- Bottom Details Tabs (Flipkart Specification grid format) -->
  <div class="pdp-details-tabs">
    <div class="tabs-header">
      <button class="tab-link active" onclick="switchTab(event, 'tab-desc')">Description</button>
      <button class="tab-link" onclick="switchTab(event, 'tab-ingredients')">Ingredients</button>
      <button class="tab-link" onclick="switchTab(event, 'tab-faqs')">FAQs</button>
    </div>
    
    <div class="tab-content active" id="tab-desc">
      <div class="specs-grid">
        <div class="spec-row"><span class="spec-label">Brand</span><span class="spec-val">{{ product.vendor }}</span></div>
        {% if product.selected_or_first_available_variant.sku != blank %}
          <div class="spec-row"><span class="spec-label">SKU</span><span class="spec-val">{{ product.selected_or_first_available_variant.sku }}</span></div>
        {% endif %}
        {% if product.selected_or_first_available_variant.weight != blank %}
          <div class="spec-row"><span class="spec-label">Weight</span><span class="spec-val">{{ product.selected_or_first_available_variant.weight | weight_with_unit }}</span></div>
        {% endif %}
      </div>
      <div class="pdp-desc-text">{{ product.description }}</div>
    </div>

    <div class="tab-content" id="tab-ingredients">
      <p>Only premium, vet-approved, 100% natural ingredients. No preservatives, fillers, or artificial chemicals.</p>
    </div>

    <div class="tab-content" id="tab-faqs">
      <div class="faq-item">
        <strong>How often should I feed this to my pet?</strong>
        <p>Refer to the daily recommendations table based on your pet's body weight.</p>
      </div>
      <div class="faq-item">
        <strong>Can I cancel the AutoShip subscription?</strong>
        <p>Yes, absolutely! You can pause, skip, or cancel your subscription plan at any time through your account portal.</p>
      </div>
    </div>
  </div>
</div>

<!-- Sticky Bottom Add-to-Cart Bar (Conversion Boost) -->
<div class="sticky-cart-bar" id="sticky-cart-bar">
  <div class="container sticky-cart-inner">
    <div class="sticky-product-details">
      <img src="{{ product.featured_image | img_url: '64x64', crop: 'center' }}" alt="{{ product.title | escape }}" />
      <div>
        <h4>{{ product.title }}</h4>
        <p>{{ product.price | money }}</p>
      </div>
    </div>
    <form method="post" action="/cart/add" onsubmit="ajaxAddToCartForm(this); return false;">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
      <button type="submit" class="btn btn-primary sticky-add-btn">Quick Add</button>
    </form>
  </div>
</div>
