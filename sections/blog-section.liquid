{%- assign blog_handle = section.settings.blog_handle | default: 'news' -%}
{%- assign blog = blogs[blog_handle] -%}
{%- assign articles_to_show = section.settings.articles_to_show | default: 3 -%}

<section class="section section--alt" aria-labelledby="blog-section-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">{{ section.settings.label | default: 'Pet Wellness' }}</span>
        <h2 class="section-title" id="blog-section-title">{{ section.settings.title | default: 'From Our Pet Experts' }}</h2>
      </div>
      {%- if blog != blank -%}
        <a href="{{ blog.url }}" class="view-all-link">
          Read all articles
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- if blog != blank and blog.articles.size > 0 -%}
      <div class="blog-grid">
        {%- for article in blog.articles limit: articles_to_show -%}
          <a href="{{ article.url }}" class="article-card" aria-label="{{ article.title }}">
            <div class="article-card__image">
              {%- if article.image != blank -%}
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 768px) 100vw, 33vw"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  class="article-card__img"
                  loading="lazy"
                  width="600" height="338"
                >
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--bg-subtle);display:flex;align-items:center;justify-content:center;">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="article-card__body">
              {%- if article.tags.size > 0 -%}
                <span class="article-card__tag">{{ article.tags.first }}</span>
              {%- elsif article.blog.title != blank -%}
                <span class="article-card__tag">{{ article.blog.title }}</span>
              {%- endif -%}
              <h3 class="article-card__title">{{ article.title }}</h3>
              {%- if article.excerpt != blank -%}
                <p class="article-card__excerpt">{{ article.excerpt | strip_html | truncate: 100 }}</p>
              {%- endif -%}
              <div class="article-card__footer">
                <span>{{ article.published_at | date: "%b %d, %Y" }}</span>
                <span style="color:var(--primary);font-weight:600;font-size:13px">Read →</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="text-muted" style="font-size:14px">
        Set your blog handle in the Theme Editor, or add articles to your Shopify blog to display them here.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog / Articles",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Pet Wellness"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "From Our Pet Experts"
    },
    {
      "type": "blog",
      "id": "blog_handle",
      "label": "Blog to display",
      "info": "Select the blog whose articles should appear here"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Number of articles",
      "default": 3
    }
  ],
  "presets": [{ "name": "Blog Articles" }]
}
{% endschema %}
