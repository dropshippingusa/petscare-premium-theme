{%- assign collection = section.settings.collection -%}
{%- assign products_to_show = section.settings.products_to_show | default: 8 -%}
{%- assign title = section.settings.title | default: 'Featured Products' -%}
{%- assign label = section.settings.label | default: 'Our Selection' -%}

<section class="section featured-products-section" aria-labelledby="featured-products-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">{{ label }}</span>
        <h2 class="section-title" id="featured-products-title">{{ title }}</h2>
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="view-all-link">
          View all {{ collection.products_count }} products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- assign products_list = collection.products -%}
    {%- if products_list.size == 0 or collection == blank -%}
      {%- assign products_list = collections.all.products -%}
    {%- endif -%}

    {%- if products_list.size > 0 -%}
      <div class="featured-products__scroll-container">
        <div class="featured-products__scroll">
          {%- for product in products_list limit: products_to_show -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>
      </div>
    {%- elsif section.settings.show_placeholder -%}
      <div class="featured-products__scroll-container">
        <div class="featured-products__scroll">
          {%- for i in (1..4) -%}
            <div class="product-card" aria-hidden="true">
              <div class="product-card__media skeleton" style="aspect-ratio:1"></div>
              <div class="product-card__body" style="gap:10px">
                <div class="skeleton" style="height:12px;width:60%;border-radius:4px"></div>
                <div class="skeleton" style="height:16px;width:90%;border-radius:4px"></div>
                <div class="skeleton" style="height:12px;width:40%;border-radius:4px"></div>
                <div class="skeleton" style="height:20px;width:50%;border-radius:4px"></div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
      <p class="text-center text-muted" style="margin-top:20px;font-size:14px">
        Select a collection in the Theme Editor to display products here.
      </p>
    {%- else -%}
      <p class="text-center text-muted" style="font-size:14px">No products found in this collection.</p>
    {%- endif -%}
  </div>
</section>

<style>
.featured-products-section {
  padding-top: 24px !important;    /* 60% spacing reduction from 64px */
  padding-bottom: 24px !important; /* 60% spacing reduction from 64px */
}
.featured-products__scroll-container {
  position: relative;
  width: 100%;
}
.featured-products__scroll {
  display: flex;
  overflow-x: auto;
  overflow-y: hidden;
  gap: 20px;
  padding: 10px 4px 24px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--primary) transparent;
}
.featured-products__scroll::-webkit-scrollbar {
  height: 6px;
}
.featured-products__scroll::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.05);
  border-radius: 9999px;
}
.featured-products__scroll::-webkit-scrollbar-thumb {
  background: var(--primary);
  border-radius: 9999px;
  opacity: 0.7;
}
.featured-products__scroll::-webkit-scrollbar-thumb:hover {
  background: var(--primary-dark);
}
.featured-products__scroll .product-card {
  flex: 0 0 280px;
  min-width: 280px;
  scroll-snap-align: start;
  background: #ffffff;
  border-radius: var(--r-xl);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: transform var(--t-base) var(--ease), box-shadow var(--t-base) var(--ease);
}
.featured-products__scroll .product-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
</style>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Our Selection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 16,
      "step": 2,
      "label": "Number of products",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show placeholder cards when no collection selected",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
