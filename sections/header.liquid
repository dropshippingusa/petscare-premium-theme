{% comment %}
  Enterprise-Grade Header with Mega Menu and Predictive Search
{% endcomment %}

<header class="header" id="header">
  <div class="header-top-banner">
    <div class="container header-top-inner">
      <span>🐾 100% Safe &amp; Natural Pet Products</span>
      <span>🇺🇸 Made in USA · Vet Approved</span>
      <span>✨ Free Shipping on Orders Over $60</span>
    </div>
  </div>
  
  <div class="header-main container">
    <!-- Logo -->
    <a href="/" class="logo">
      <span class="logo-paw">🐾</span>
      <span class="logo-text">PetsCare<span class="logo-dot">.com</span></span>
    </a>

    <!-- Prominent Search Bar (Flipkart/Amazon style) with Predictive Search Results Dropdown -->
    <div class="header-search-wrap">
      <form action="/search" method="get" class="search-form" id="predictive-search-form">
        <input type="text" name="q" id="search-input" placeholder="Search for products, brands, pet issues, ingredients..." value="{{ search.terms | escape }}" class="search-input-field" autocomplete="off" required />
        <button type="submit" class="search-submit-btn" aria-label="Search">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
      </form>
      <!-- Predictive Search Box Panel -->
      <div class="predictive-search-results" id="predictive-search-box">
        <div class="predictive-search-loading">Searching...</div>
      </div>
    </div>

    <!-- Right Actions -->
    <div class="header-actions">
      <a href="/account" class="header-account-link">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Account</span>
      </a>
      <button class="icon-btn cart-icon-btn" id="cart-icon-trigger" aria-label="Cart">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" id="header-cart-count">{{ cart.item_count }}</span>
      </button>
      <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>

  <!-- Navigation Menu Bar with Custom Mega Menus -->
  <div class="header-nav-bar">
    <div class="container">
      <nav class="nav" id="main-nav">
        <ul class="nav-list">
          <li class="nav-item-dropdown">
            <a href="/collections/all" class="nav-link">Shop Products ▾</a>
            
            <!-- Mega Menu Container -->
            <div class="mega-menu">
              <div class="mega-menu-grid">
                <!-- Col 1: Shop By Pet -->
                <div class="mega-menu-col">
                  <h5>Shop By Pet</h5>
                  <ul>
                    <li><a href="/collections/dogs">🐕 Dogs Collection</a></li>
                    <li><a href="/collections/cats">🐈 Cats Collection</a></li>
                    <li><a href="/collections/all">🐾 All Pets</a></li>
                  </ul>
                </div>
                <!-- Col 2: Shop By Category -->
                <div class="mega-menu-col">
                  <h5>Shop By Category</h5>
                  <ul>
                    <li><a href="/collections/supplements">💊 Supplements</a></li>
                    <li><a href="/collections/health">🩺 Health &amp; Dental</a></li>
                    <li><a href="/collections/treats">🥩 Treats &amp; Food</a></li>
                    <li><a href="/collections/accessories">🎒 Travel &amp; Accessories</a></li>
                  </ul>
                </div>
                <!-- Col 3: Special Programs -->
                <div class="mega-menu-col">
                  <h5>Programs &amp; Deals</h5>
                  <ul>
                    <li><a href="/collections/all">⭐ Subscription Plans</a></li>
                    <li><a href="/collections/all">🔥 Today's Flash Deals</a></li>
                    <li><a href="/collections/all">🧑‍⚕️ Vet Recommended</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </li>
          <li><a href="/collections/all" class="nav-link">Best Sellers</a></li>
          <li><a href="/pages/about" class="nav-link">Our Story</a></li>
          <li><a href="/pages/contact" class="nav-link">Contact</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
