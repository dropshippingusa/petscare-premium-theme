<section class="section section--alt" aria-labelledby="categories-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">{{ section.settings.label | default: 'Browse by Category' }}</span>
        <h2 class="section-title" id="categories-title">{{ section.settings.title | default: 'Everything Your Pet Needs' }}</h2>
      </div>
    </div>

    <div class="category-grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign cat_url = block.settings.collection.url | default: block.settings.fallback_url | default: '/collections/all' -%}
        <a href="{{ cat_url }}" class="category-card" role="listitem" {{ block.shopify_attributes }} aria-label="{{ block.settings.name }}">
          <div class="category-card__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'health' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              {%- when 'food' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
              {%- when 'treats' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
              {%- when 'dental' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
              {%- when 'travel' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
              {%- when 'beds' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9V5a2 2 0 012-2h16a2 2 0 012 2v4"/><path d="M2 9h20v9a2 2 0 01-2 2H4a2 2 0 01-2-2V9z"/><line x1="6" y1="9" x2="6" y2="20"/><line x1="18" y1="9" x2="18" y2="20"/></svg>
              {%- when 'cleaning' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 007-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 007 7z"/></svg>
              {%- when 'accessories' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
              {%- when 'training' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 10-16 0"/><line x1="12" y1="12" x2="12" y2="21"/></svg>
              {%- when 'toys' -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
              {%- else -%}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            {%- endcase -%}
          </div>
          <span class="category-card__name">{{ block.settings.name }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Everything Your Pet Needs"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "health", "label": "Health / Supplements" },
            { "value": "food", "label": "Food / Nutrition" },
            { "value": "treats", "label": "Treats" },
            { "value": "dental", "label": "Dental Care" },
            { "value": "travel", "label": "Travel / Carriers" },
            { "value": "beds", "label": "Beds / Sleep" },
            { "value": "cleaning", "label": "Cleaning / Grooming" },
            { "value": "accessories", "label": "Accessories" },
            { "value": "training", "label": "Training" },
            { "value": "toys", "label": "Toys" }
          ],
          "default": "health"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Health"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to collection"
        },
        {
          "type": "url",
          "id": "fallback_url",
          "label": "Fallback URL (if no collection selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "icon": "health", "name": "Health" } },
        { "type": "category", "settings": { "icon": "food", "name": "Food" } },
        { "type": "category", "settings": { "icon": "treats", "name": "Treats" } },
        { "type": "category", "settings": { "icon": "dental", "name": "Dental" } },
        { "type": "category", "settings": { "icon": "travel", "name": "Travel" } },
        { "type": "category", "settings": { "icon": "beds", "name": "Beds" } },
        { "type": "category", "settings": { "icon": "cleaning", "name": "Cleaning" } },
        { "type": "category", "settings": { "icon": "accessories", "name": "Accessories" } },
        { "type": "category", "settings": { "icon": "training", "name": "Training" } },
        { "type": "category", "settings": { "icon": "toys", "name": "Toys" } }
      ]
    }
  ]
}
{% endschema %}
