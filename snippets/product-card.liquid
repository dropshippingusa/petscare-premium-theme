{% comment %}
  Flipkart/Chewy-style Product Card Snippet
{% endcomment %}

{%- assign discount_price = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign discount_price = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
{%- endif -%}

<div class="product-card" data-product-id="{{ product.id }}">
  <div class="product-img-wrap">
    <!-- Badges -->
    <div class="product-badges">
      {% if product.compare_at_price > product.price %}
        <span class="badge-tag sale-tag">{{ discount_price }}% OFF</span>
      {% endif %}
      {% if product.tags contains 'new' %}
        <span class="badge-tag new-tag">New</span>
      {% endif %}
    </div>

    <!-- Image -->
    <a href="{{ product.url }}" class="product-img-link">
      {% if product.featured_image != blank %}
        <img class="lazyload" src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title | escape }}" loading="lazy">
      {% else %}
        <div class="product-img-placeholder">🐾</div>
      {% endif %}
    </a>

    <!-- Wishlist Button -->
    <button class="wish-btn" onclick="toggleWishlist('{{ product.id }}')" aria-label="Add to Wishlist">♡</button>
  </div>

  <div class="product-info">
    <p class="product-brand">{{ product.vendor }}</p>
    <h3 class="product-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    
    <!-- Rating (Flipkart Style Green Badge) -->
    <div class="product-rating-row">
      <span class="rating-badge">4.9 ★</span>
      <span class="rating-count">(47 reviews)</span>
    </div>

    <!-- Pricing (Flipkart Style: Price, Strikethrough, Green Discount) -->
    <div class="price-row">
      <span class="price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="old-price">{{ product.compare_at_price | money }}</span>
        <span class="discount-percent">{{ discount_price }}% off</span>
      {% endif %}
    </div>

    <!-- Stock / Shipping Badge -->
    <div class="shipping-badge">
      <span>⚡ Fast Shipping</span>
      <span class="sep">•</span>
      <span>🇺🇸 Made in USA</span>
    </div>

    <!-- Add to Cart (Visible Flipkart Style Button) -->
    <div class="product-card-action">
      <form method="post" action="/cart/add" onsubmit="ajaxAddToCartForm(this); return false;">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
        <button type="submit" class="btn-card-add">Add to Cart</button>
      </form>
    </div>
  </div>
</div>
