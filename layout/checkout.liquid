<!DOCTYPE html>
<html lang="{{ locale }}" class="{{ checkout_html_classes }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0, user-scalable=0">
    <meta name="referrer" content="origin">

    <title>{{ page_title }}</title>

    {{ content_for_header }}

    {{ checkout_stylesheets }}
    {{ checkout_scripts }}

    <!-- Load Rubik font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
      /* --- Custom Checkout Styling --- */
      body, input, select, textarea, button {
        font-family: 'Rubik', system-ui, -apple-system, sans-serif !important;
      }
      
      .custom-checkout-nav {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 16px 0 24px 0;
        width: 100%;
      }
      
      .checkout-nav-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        flex: 1;
        height: 46px;
        padding: 0 16px;
        font-size: 14px;
        font-weight: 500;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        border: 1px solid #D1D5DB;
        box-sizing: border-box;
      }
      
      .checkout-nav-btn--back {
        background-color: #FFFFFF;
        color: #333333;
      }
      
      .checkout-nav-btn--back:hover {
        background-color: #F9F9F9;
        border-color: #9CA3AF;
      }
      
      .checkout-nav-btn--add {
        background-color: #FD8542;
        color: #FFFFFF;
        border-color: #FD8542;
      }
      
      .checkout-nav-btn--add:hover {
        background-color: #E36C29;
        border-color: #E36C29;
        box-shadow: 0 4px 12px rgba(253, 133, 66, 0.15);
      }
      
      .checkout-nav-btn svg {
        flex-shrink: 0;
        transition: transform 0.2s ease;
      }
      
      .checkout-nav-btn--back:hover svg {
        transform: translateX(-2px);
      }
      
      .checkout-nav-btn--add:hover svg {
        transform: scale(1.1);
      }
      
      /* Mobile responsive adjustments */
      @media (max-width: 767px) {
        .custom-checkout-nav {
          gap: 8px;
          margin: 12px 0 20px 0;
        }
        .checkout-nav-btn {
          height: 42px;
          padding: 0 12px;
          font-size: 13px;
          border-radius: 6px;
        }
      }
    </style>
  </head>
  <body>
    {{ skip_to_content_link }}

    <header class="banner" role="banner" data-header>
      <div class="wrap">
        {{ content_for_logo }}
      </div>
    </header>

    {{ order_summary_toggle }}
    <div class="content" data-content>
      <div class="wrap">
        <div class="main">
          <header class="main__header" role="banner">
            {{ content_for_logo }}
            {{ breadcrumb }}
            
            <!-- Custom Navigation Links -->
            <div class="custom-checkout-nav">
              <a href="/cart" class="checkout-nav-btn checkout-nav-btn--back">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                <span>Back to Cart</span>
              </a>
              <a href="/collections/all" class="checkout-nav-btn checkout-nav-btn--add">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                <span>Add Another Item</span>
              </a>
            </div>

            {{ alternative_payment_methods }}
          </header>
          <main class="main__content" role="main">
            {{ content_for_layout }}
          </main>
          <footer class="main__footer" role="contentinfo">
            {{ content_for_footer }}
          </footer>
        </div>
        <aside class="sidebar" role="complementary">
          <div class="sidebar__header">
            {{ content_for_logo }}
          </div>
          <div class="sidebar__content">
            {{ content_for_order_summary }}
          </div>
        </aside>
      </div>
    </div>

    {{ tracking_code }}

    {%- comment -%} Calculate total savings from compare_at_price vs actual price {%- endcomment -%}
    {%- assign total_savings = 0 -%}
    {%- for item in checkout.line_items -%}
      {%- if item.variant.compare_at_price > item.variant.price -%}
        {%- assign savings_diff = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity -%}
        {%- assign total_savings = total_savings | plus: savings_diff -%}
      {%- endif -%}
    {%- endfor -%}

    <div id="custom-checkout-savings" data-savings-amount="{{ total_savings }}" data-savings-formatted="-{{ total_savings | money }}" style="display: none;"></div>

    <script>
      (function() {
        function injectSavings() {
          const savingsData = document.getElementById('custom-checkout-savings');
          if (!savingsData) return;
          
          const savingsAmount = parseInt(savingsData.getAttribute('data-savings-amount'), 10);
          const savingsFormatted = savingsData.getAttribute('data-savings-formatted');
          
          if (savingsAmount <= 0) return;
          
          // Find the subtotal row in the order summary table
          const subtotalRow = document.querySelector('.total-line--subtotal');
          if (!subtotalRow) return;
          
          // Check if savings row is already injected to prevent duplication
          if (document.querySelector('.total-line--savings')) return;
          
          // Create the savings row HTML with design styling matching the cart page savings block
          const savingsRowHtml = `
            <tr class="total-line total-line--savings">
              <td colspan="2" style="padding: 8px 0;">
                <div class="checkout-savings-banner" style="display: flex; justify-content: space-between; align-items: center; background: #f0fdf4; border: 1px dashed #bbf7d0; color: #16a34a; padding: 10px 14px; border-radius: 8px; font-weight: 700; font-size: 13.5px; font-family: 'Rubik', sans-serif;">
                  <span>🎉 Total Savings</span>
                  <span style="font-size: 14.5px;">` + savingsFormatted + `</span>
                </div>
              </td>
            </tr>
          `;
          
          // Insert the savings row right after the subtotal row
          subtotalRow.insertAdjacentHTML('afterend', savingsRowHtml);
        }
        
        function initObserver() {
          injectSavings();
          
          // Use MutationObserver to ensure the savings row persists during AJAX checkout step updates
          const summaryTable = document.querySelector('.total-line-table');
          if (summaryTable) {
            const observer = new MutationObserver(function() {
              injectSavings();
            });
            observer.observe(summaryTable, { childList: true, subtree: true });
          }
        }
        
        // Listen to native page events as well as standard DOM loading
        document.addEventListener('DOMContentLoaded', initObserver);
        document.addEventListener('page:load', initObserver);
        document.addEventListener('page:change', initObserver);
        
        // Run immediately in case script is parsed late
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
          initObserver();
        }
      })();
    </script>
  </body>
</html>
