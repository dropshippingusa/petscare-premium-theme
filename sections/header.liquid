{%- liquid
  assign msg_1 = section.settings.announcement_1 | default: 'Free shipping on orders $49+'
  assign msg_2 = section.settings.announcement_2 | default: 'Secure Checkout: Shop with confidence'
  assign msg_3 = section.settings.announcement_3 | default: 'Fast US Shipping: Formulated & Packaged in the USA'
  assign msg_4 = section.settings.announcement_4 | default: '30-Day Money Back Guarantee: 100% Risk-Free'
-%}

<div class="announcement-bar" id="announcement-bar-ticker" role="region" aria-label="Announcements">
  <div class="announcement-bar__ticker">
    <div class="announcement-slide is-active" role="group" aria-label="1 of 4">{{ msg_1 }}</div>
    <div class="announcement-slide" role="group" aria-label="2 of 4" style="display: none;">{{ msg_2 }}</div>
    <div class="announcement-slide" role="group" aria-label="3 of 4" style="display: none;">{{ msg_3 }}</div>
    <div class="announcement-slide" role="group" aria-label="4 of 4" style="display: none;">{{ msg_4 }}</div>
  </div>
</div>

<header class="site-header" role="banner">
  <div class="header-inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="/" class="header-logo" aria-label="{{ shop.name }} — Home">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="15" fill="currentColor"/>
        <path d="M10 13a2 2 0 100-4 2 2 0 000 4zM22 13a2 2 0 100-4 2 2 0 000 4zM8 18a2 2 0 100-4 2 2 0 000 4zM24 18a2 2 0 100-4 2 2 0 000 4zM16 24a4 4 0 100-8 4 4 0 000 8z" fill="white"/>
      </svg>
      {{ shop.name }}
    </a>

    {%- comment -%} Primary navigation using Shopify linklists {%- endcomment -%}
    <nav class="header-nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links.size > 0 -%}
          <div style="position:relative;">
            <button
              class="header-nav__link"
              data-mega-trigger="{{ link.handle }}"
              aria-expanded="false"
              aria-haspopup="true"
            >
              {{ link.title }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="mega-menu" data-mega-menu="{{ link.handle }}" role="region" aria-label="{{ link.title }} menu">
              <div class="mega-menu__inner">
                {%- comment -%} Group sub-links into columns of 4 {%- endcomment -%}
                {%- assign cols = link.links | split: ',' -%}
                {%- assign col_size = 4 -%}
                {%- assign col_count = link.links.size | divided_by: col_size | ceil -%}
                {%- for col_idx in (0..3) -%}
                  <div>
                    <p class="mega-menu__col-title" aria-hidden="true">
                      {%- if col_idx == 0 -%}Shop by Pet{%- endif -%}
                      {%- if col_idx == 1 -%}Categories{%- endif -%}
                      {%- if col_idx == 2 -%}Health Concerns{%- endif -%}
                      {%- if col_idx == 3 -%}Quick Links{%- endif -%}
                    </p>
                    {%- for sub_link in link.links -%}
                      {%- assign sub_idx = forloop.index0 -%}
                      {%- if sub_idx >= col_idx | times: col_size and sub_idx < col_idx | plus: 1 | times: col_size -%}
                        <a href="{{ sub_link.url }}" class="mega-menu__link">
                          <span class="mega-menu__link-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                          </span>
                          {{ sub_link.title }}
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="header-nav__link" {% if link.active %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    {%- comment -%} Header action icons {%- endcomment -%}
    <div class="header-actions">
      <button type="button" class="icon-btn" data-open-search aria-label="Search products">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}/account{%- else -%}/account/login{%- endif -%}" class="icon-btn" aria-label="{%- if customer -%}My account{%- else -%}Sign in{%- endif -%}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {%- endif -%}

      <button type="button" class="header-cart-btn" data-open-cart aria-label="Open shopping bag ({{ cart.item_count }} items)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-count" id="header-cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Ticker"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Message 1",
      "default": "Free shipping on orders $49+"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Message 2",
      "default": "Secure Checkout: Shop with confidence"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Message 3",
      "default": "Fast US Shipping: Formulated & Packaged in the USA"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Message 4",
      "default": "30-Day Money Back Guarantee: 100% Risk-Free"
    }
  ]
}
{% endschema %}
