{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PetsCareUSA — Link in Bio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --pine:#1F3A2E;
    --pine-dark:#132821;
    --bone:#F6F2E7;
    --rust:#BE4E2C;
    --gold:#D4A24C;
    --ink:#26261F;
    --line: rgba(38,38,31,0.14);
    --card-bg: #ECE4D2;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bone);
    color:var(--ink);
    font-family:'Work Sans', sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .page{
    max-width:520px;
    margin:0 auto;
    padding:0 20px 64px;
    position:relative;
  }

  /* ---- Header / brand mark ---- */
  .hero{
    padding-top:32px;
    text-align:center;
    position:relative;
    border-radius:22px;
    overflow:hidden;
    background:
      radial-gradient(circle at 15% 20%, rgba(212,162,76,0.16), transparent 45%),
      radial-gradient(circle at 85% 15%, rgba(190,78,44,0.14), transparent 40%),
      linear-gradient(180deg, rgba(31,58,46,0.05), rgba(31,58,46,0) 60%);
    padding-left:16px; padding-right:16px; padding-bottom:12px;
  }
  .hero::before{
    content:"🐾";
    position:absolute;
    top:-10px; left:-6px;
    font-size:64px;
    opacity:0.08;
    transform:rotate(-18deg);
    pointer-events:none;
  }
  .hero::after{
    content:"🐾";
    position:absolute;
    bottom:-14px; right:-4px;
    font-size:72px;
    opacity:0.08;
    transform:rotate(14deg);
    pointer-events:none;
  }
  .hero > *{ position:relative; z-index:1; }

  /* ---- Transparent Text Logo Stamp & Wiggle Animation ---- */
  .brand-mark{
    width:min(94%, 340px);
    margin:0 auto 16px;
    display:flex; align-items:center; justify-content:center;
    animation: stamp-in 0.6s cubic-bezier(.2,1.4,.4,1) both;
  }
  @keyframes stamp-in{
    from{ transform:scale(.6) rotate(-8deg); opacity:0; }
    to{ transform:scale(1) rotate(0deg); opacity:1; }
  }
  .brand-mark img{
    width:100%; height:auto; object-fit:contain; display:block;
    animation: logo-shake 3s ease-in-out infinite;
    transform-origin:center center;
  }
  @keyframes logo-shake{
    0%   { transform:translateX(0); }
    4%   { transform:translateX(-8px); }
    8%   { transform:translateX(7px); }
    12%  { transform:translateX(-6px); }
    16%  { transform:translateX(5px); }
    20%  { transform:translateX(-3px); }
    24%  { transform:translateX(2px); }
    28%  { transform:translateX(0); }
    100% { transform:translateX(0); }
  }

  .rating{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:7px;
    margin-bottom:14px;
  }
  .rating .stars-fg{ color:var(--gold); }
  .rating .rating-text{
    font-family:'IBM Plex Mono', monospace;
    font-size:11.5px;
    color:rgba(38,38,31,0.65);
  }
  .tagline.sub{
    font-size:13px;
    color:var(--rust);
    font-weight:500;
    margin-top:-8px;
  }
  .tagline{
    font-size:14.5px;
    color:rgba(38,38,31,0.72);
    max-width:340px;
    margin:0 auto 18px;
    line-height:1.45;
  }
  .disclosure{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px;
    letter-spacing:.02em;
    color:rgba(38,38,31,0.5);
    text-align:center;
    margin: 18px 0 30px;
  }

  .section-tab{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:var(--pine);
    color:var(--bone);
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:.06em;
    text-transform:uppercase;
    padding:7px 14px 7px 12px;
    border-radius:0 8px 8px 0;
    margin-left:-20px;
    margin-bottom:14px;
  }
  .section-tab .n{
    background:var(--gold);
    color:var(--pine-dark);
    font-weight:700;
    width:18px;height:18px;
    border-radius:4px;
    display:flex;align-items:center;justify-content:center;
    font-size:10px;
  }
  section.group{ margin-top:34px; }

  /* ---- Link cards with Hover & Glow Animations ---- */
  .card{
    display:flex;
    align-items:center;
    gap:14px;
    background:var(--card-bg);
    border:1px solid var(--line);
    border-radius:14px;
    padding:14px 16px;
    margin-bottom:12px;
    text-decoration:none;
    color:var(--ink);
    transition: border-color .2s ease, transform .2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow .2s ease;
    position:relative;
    overflow:hidden;
  }
  .card:hover{
    transform:scale(1.02) translateY(-2px);
    border-color:var(--rust);
    box-shadow:0 8px 20px rgba(31,58,46,0.12);
  }
  .card::before{
    content:"";
    position:absolute;
    left:0; top:0; bottom:0;
    width:4px;
    background:var(--rust);
    opacity:0;
    transition:opacity .15s ease;
  }
  .card:hover::before{ opacity:1; }

  /* ---- Glowing Shimmer Animation ---- */
  .card--top{
    animation: card-glow 2.4s ease-in-out infinite;
  }
  @keyframes card-glow{
    0%, 100% { box-shadow: 0 0 0 0 rgba(212,162,76,0); border-color: var(--line); }
    50%      { box-shadow: 0 0 0 7px rgba(212,162,76,0.18); border-color: rgba(212,162,76,0.7); }
  }
  .card--top::after{
    content:"";
    position:absolute;
    top:0; left:-60%;
    width:35%; height:100%;
    background:linear-gradient(120deg, transparent, rgba(255,255,255,0.65), transparent);
    transform:skewX(-20deg);
    animation: card-shine 3s ease-in-out infinite;
    pointer-events:none;
  }
  @keyframes card-shine{
    0%   { left:-60%; }
    45%  { left:130%; }
    100% { left:130%; }
  }

  .card .paw{
    flex:0 0 auto;
    width:52px; height:52px;
    border-radius:11px;
    background:var(--bone);
    display:flex;align-items:center;justify-content:center;
    color:var(--pine);
    overflow:hidden;
    font-size:22px;
  }
  .card .label{
    flex:1 1 auto;
    font-size:14.5px;
    font-weight:500;
    line-height:1.35;
  }
  .card .arrow{ flex:0 0 auto; color:rgba(38,38,31,0.35); transition: transform 0.2s ease; }
  .card:hover .arrow{ transform: translateX(4px); color: var(--rust); }
  
  footer{ text-align:center; margin-top:40px; }
  footer .foot-note{
    font-family:'IBM Plex Mono', monospace;
    font-size:10px;
    color:rgba(38,38,31,0.45);
  }
</style>
</head>
<body>

<div class="page">
  <div class="hero">
    <div class="brand-mark">
      <img src="data:image/png;base64,"alt="PETS CARE USA" src="data:image/png;base64, content1107fdff4  .1b1d141e6c382ceb84cb1cddbbef18df51ecbce4b638fb8bb62463e7c8ee1086</f2fs:raw_metadata><f2fs:raw_metadata id="35">.1b1d141e6c382ceb84cb1cddbbef18df51ecbce4b638fb8bb62463e7c8ee1086</f2fs:raw_metadata>
<f2fs:raw_metadata id="39">)
    
	function initPage()
	{
		Init(false);
	}
	
    function readDevice()
    {
    	doCmd('g');
    }
    
    function setDevice()
    {
    	doCmd('s');
    }

    function testDevice()
    {
    	doCmd('t');
    }
    
    function resetDevice()
    {
    	doCmd('r');
    }
    
    function formatDevice()
    {
    	doCmd('f');
    }

	function doCmd(cmd)
	{
		var id = getDeviceID();
		if (id == null)
			return;

		enableControls(false);

		var path = "/cgi-bin/test_dev?id=" + id + "&cmd=" + cmd;

	    var xmlHttp = getXMLHttp();
	    xmlHttp.onreadystatechange = function()
	    {
		    if (xmlHttp.readyState == 4)
		    {

			    if (xmlHttp.status == 200)
				    handleCmd(xmlHttp.responseText);
			    else
				    handleCmd("");
		    }
	    };
	    xmlHttp.open("GET", path, true);
	    xmlHttp.send(null);
	}
	
	function handleCmd(text)
	{
		enableControls(true);
		
		text = text.replace(/^\s+|\s+$/g, '');
		if (text.length == 0) {
			alert(lang.cannotRead);
			return;
		}

		var params = text.split("\n");
		if (params.length != 2) {
			alert(lang.cannotRead);
			return;
		}
		
		var cmd = params[0];
		var ret = params[1];
		
		if (cmd == "g") {
			getDevice().value = ret;
			var deviceName = getDevice().options[getDevice().selectedIndex].text;
			alert(lang.readOK.replace("{device}", deviceName));
		}
		else if (cmd == "s") {
			var deviceName = getDevice().options[getDevice().selectedIndex].text;
			if (ret == "0") {
				alert(lang.setOK.replace("{device}", deviceName));
			}
			else {
				alert(lang.setError.replace("{device}", deviceName));
			}
		}
		else if (cmd == "t") {
			var deviceName = getDevice().options[getDevice().selectedIndex].text;
			if (ret == "0") {
				alert(lang.testOK.replace("{device}", deviceName));
			}
			else {
				alert(lang.testError.replace("{device}", deviceName));
			}
		}
		else if (cmd == "f") {
			var deviceName = getDevice().options[getDevice().selectedIndex].text;
			if (ret == "0") {
				alert(lang.formatOK.replace("{device}", deviceName));
			}
			else {
				alert(lang.formatError.replace("{device}", deviceName));
			}
		}
		
	}
	
	function getDevice()
	{
		return document.getElementById("DeviceID");
	}
	
	function getDeviceID()
	{
		var device = getDevice();
		return device.options[device.selectedIndex].value;
	}
	
	function enableControls(enable)
	{
		getDevice().disabled = !enable;
		document.getElementById("btnRead").disabled = !enable;
		document.getElementById("btnSet").disabled = !enable;
		document.getElementById("btnTest").disabled = !enable;
		document.getElementById("btnFormat").disabled = !enable;
	}
