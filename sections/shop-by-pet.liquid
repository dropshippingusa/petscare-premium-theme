{%- assign collection = section.settings.collection -%}
{%- if collection == blank -%}
  {%- for coll in collections -%}
    {%- if coll.title == 'Top Picks' -%}
      {%- assign collection = coll -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- if collection == blank or collection.products.size == 0 -%}
  {%- assign collection = collections.all -%}
{%- endif -%}

{%- assign products_to_show = section.settings.products_to_show | default: 10 -%}
{%- assign title = section.settings.title | default: 'Top Picks' -%}
{%- assign label = section.settings.label | default: 'Trending' -%}

<section class="section top-picks-section" aria-labelledby="top-picks-title">
  <div class="container">
    <div class="section-head" style="margin-bottom: var(--sp-4);">
      <div>
        <span class="section-label">{{ label }}</span>
        <h2 class="section-title" id="top-picks-title">{{ title }}</h2>
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="view-all-link">
          View All
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="top-picks__scroll-container">
      <div class="top-picks__scroll">
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- else -%}
          {%- for i in (1..5) -%}
            <div class="product-card" aria-hidden="true">
              <div class="product-card__media skeleton" style="aspect-ratio:1"></div>
              <div class="product-card__body" style="gap:10px">
                <div class="skeleton" style="height:12px;width:60%;border-radius:4px"></div>
                <div class="skeleton" style="height:16px;width:90%;border-radius:4px"></div>
                <div class="skeleton" style="height:12px;width:40%;border-radius:4px"></div>
                <div class="skeleton" style="height:20px;width:50%;border-radius:4px"></div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
.top-picks-section {
  background-color: var(--bg-alt);
  padding-top: 18px;
  padding-bottom: var(--sp-5);
}
.top-picks__scroll-container {
  position: relative;
  width: 100%;
}
.top-picks__scroll {
  display: flex;
  overflow-x: auto;
  overflow-y: hidden;
  gap: 20px;
  padding: 10px 4px 24px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--primary) transparent;
}
.top-picks__scroll::-webkit-scrollbar {
  height: 6px;
}
.top-picks__scroll::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.05);
  border-radius: 9999px;
}
.top-picks__scroll::-webkit-scrollbar-thumb {
  background: var(--primary);
  border-radius: 9999px;
  opacity: 0.7;
}
.top-picks__scroll::-webkit-scrollbar-thumb:hover {
  background: var(--primary-dark);
}
.top-picks__scroll .product-card {
  flex: 0 0 280px;
  min-width: 280px;
  scroll-snap-align: start;
  background: #ffffff;
  border-radius: var(--r-xl);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: transform var(--t-base) var(--ease), box-shadow var(--t-base) var(--ease);
}
.top-picks__scroll .product-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary);
}
@media (max-width: 768px) {
  .top-picks__scroll {
    gap: 12px;
    padding-bottom: 16px;
  }
  .top-picks__scroll .product-card {
    flex: 0 0 220px;
    min-width: 220px;
  }
}
</style>

{% schema %}
{
  "name": "Top Picks",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Trending"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Top Picks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Number of products",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Top Picks"
    }
  ]
}
{% endschema %}
