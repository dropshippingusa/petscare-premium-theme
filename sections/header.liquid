{%- liquid
  assign msg_1 = section.settings.announcement_1 | default: 'Free shipping on orders $49+'
  assign msg_2 = section.settings.announcement_2 | default: 'Secure Checkout: Shop with confidence'
  assign msg_3 = section.settings.announcement_3 | default: 'Fast US Shipping: Formulated & Packaged in the USA'
  assign msg_4 = section.settings.announcement_4 | default: '30-Day Money Back Guarantee: 100% Risk-Free'
-%}

<div class="announcement-bar" id="announcement-bar-ticker" role="region" aria-label="Announcements">
  <div class="announcement-bar__ticker">
    <div class="announcement-slide is-active" role="group" aria-label="1 of 4">{{ msg_1 }}</div>
    <div class="announcement-slide" role="group" aria-label="2 of 4" style="display: none;">{{ msg_2 }}</div>
    <div class="announcement-slide" role="group" aria-label="3 of 4" style="display: none;">{{ msg_3 }}</div>
    <div class="announcement-slide" role="group" aria-label="4 of 4" style="display: none;">{{ msg_4 }}</div>
  </div>
</div>

<header class="site-header" role="banner">
  
  <!-- Top Row -->
  <div class="header-top-row">
    <div class="header-inner-top">
      <!-- Logo -->
      <a href="/" class="header-logo" aria-label="{{ shop.name }} — Home">
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img" width="160" height="40">
      </a>

      <!-- Search Bar -->
      <form action="/search" method="get" class="header-search-form" role="search">
        <span class="header-search-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input 
          type="text" 
          name="q" 
          placeholder="Search for Dog Food, Cat Food, Toys..." 
          class="header-search-input"
          aria-label="Search store"
        >
      </form>

      <!-- Top Actions -->
      <div class="header-actions">
        <!-- Location -->
        <div class="header-action-item header-location-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Location</span>
        </div>

        <!-- Wishlist -->
        <a href="/pages/wishlist" class="header-action-item header-wishlist-btn" style="text-decoration:none;" aria-label="View wishlist">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          <span>Wishlist</span>
        </a>

        <!-- Cart -->
        <button type="button" class="header-action-item header-cart-btn" data-open-cart aria-label="Open shopping bag ({{ cart.item_count }} items)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span>Cart</span>
          <span class="cart-count" id="header-cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </button>

        <!-- Login/Sign Up Orange Button -->
        {%- if customer -%}
          <a href="/account" class="header-login-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Account</span>
          </a>
        {%- else -%}
          <a href="/account/login" class="header-login-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Login/Sign Up</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="header-bottom-row">
    <div class="header-inner-bottom">
      <nav class="header-nav" aria-label="Main navigation">
        <a href="/" class="header-nav__link">Home</a>
        <a href="/collections/all?pet=dogs" class="header-nav__link">Dogs</a>
        <a href="/collections/all?pet=cats" class="header-nav__link">Cats</a>
      </nav>
    </div>
  </div>

</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Ticker"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Message 1",
      "default": "Free shipping on orders $49+"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Message 2",
      "default": "Secure Checkout: Shop with confidence"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Message 3",
      "default": "Fast US Shipping: Formulated & Packaged in the USA"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Message 4",
      "default": "30-Day Money Back Guarantee: 100% Risk-Free"
    }
  ]
}
{% endschema %}
