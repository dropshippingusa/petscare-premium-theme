{%- liquid
  assign msg_1 = section.settings.announcement_1 | default: '🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout'
  assign msg_2 = section.settings.announcement_2 | default: 'Free shipping on orders $49+'
  assign msg_3 = section.settings.announcement_3 | default: 'Secure Checkout: Shop with confidence'
  assign msg_4 = section.settings.announcement_4 | default: 'Fast US Shipping: Formulated & Packaged in the USA'
  assign msg_5 = section.settings.announcement_5 | default: 'Hassle-Free Returns: Shop Risk-Free'
-%}

<div class="site-header-wrapper" id="site-header-wrapper">
<div class="announcement-bar" id="announcement-bar-ticker" role="region" aria-label="Announcements">
  <div class="announcement-bar__ticker">
    <div class="announcement-slide is-active" role="group" aria-label="1 of 5">{{ msg_1 }}</div>
    <div class="announcement-slide" role="group" aria-label="2 of 5" style="display: none;">{{ msg_2 }}</div>
    <div class="announcement-slide" role="group" aria-label="3 of 5" style="display: none;">{{ msg_3 }}</div>
    <div class="announcement-slide" role="group" aria-label="4 of 5" style="display: none;">{{ msg_4 }}</div>
    <div class="announcement-slide" role="group" aria-label="5 of 5" style="display: none;">{{ msg_5 }}</div>
  </div>
</div>

<header class="site-header" role="banner">
  <div class="header-container">
    
    <!-- Left side: Combined Height Logo -->
    <a href="/" class="header-logo-container" aria-label="{{ shop.name }} — Home">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--default">
      <img src="{{ 'logo-sticky.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--sticky" style="display: none;">
    </a>
    
    <!-- Right side: Three stacked rows -->
    <div class="header-right-stacked">
      
      <!-- Row 1: Location Bar (Top Right) -->
      <div class="header-location-row">
        <div class="header-location-picker">
          <svg class="loc-pin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="loc-zip">90210</span>
          <span class="loc-link">Select delivery location <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 2px; display: inline-block; vertical-align: middle;"><polyline points="9 18 15 12 9 6"/></svg></span>
        </div>
      </div>

      <!-- Row 2: Search and Actions -->
      <div class="header-main-row">
        <!-- Search Bar -->
        <form action="/search" method="get" class="header-search-form" role="search">
          <span class="header-search-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <input 
            type="text" 
            name="q" 
            placeholder="Search for Products, Brands and More" 
            class="header-search-input"
            aria-label="Search store"
          >
        </form>

        <!-- Actions (Flipkart style) -->
        <div class="header-actions">
          <!-- Login Link -->
          <div class="header-action-dropdown">
            {%- if customer -%}
              <a href="/account" class="header-action-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Account</span>
                <svg class="chevron-down" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
            {%- else -%}
              <a href="/account/login" class="header-action-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Login</span>
                <svg class="chevron-down" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
            {%- endif -%}
          </div>

          <!-- Wishlist Link -->
          <a href="/pages/wishlist" class="header-action-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            <span>Wishlist</span>
          </a>

          <!-- Cart Link (Simple, matching Flipkart style) -->
          <button type="button" class="header-action-link header-cart-btn" data-open-cart>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
            <span>Cart</span>
            <span class="cart-count-badge" id="header-cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
          </button>
        </div>
      </div>

      <!-- Row 3: Navigation Capsule -->
      <div class="header-nav-row">
        <nav class="header-nav" aria-label="Main navigation">
          <a href="/" class="header-nav__link">Home</a>
          <a href="/collections/all?pet=dogs" class="header-nav__link">Dogs</a>
          <a href="/collections/all?pet=cats" class="header-nav__link">Cats</a>
        </nav>
      </div>

    </div>
  </div>
</header>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Ticker"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Message 1",
      "default": "🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Message 2",
      "default": "Free shipping on orders $49+"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Message 3",
      "default": "Secure Checkout: Shop with confidence"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Message 4",
      "default": "Fast US Shipping: Formulated & Packaged in the USA"
    },
    {
      "type": "text",
      "id": "announcement_5",
      "label": "Message 5",
      "default": "Hassle-Free Returns: Shop Risk-Free"
    }
  ]
}
{% endschema %}
