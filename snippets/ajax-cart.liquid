<div class="cart-drawer-overlay" id="cart-drawer-overlay"></div>
<div class="cart-drawer" id="cart-drawer">
  <!-- Shipping Progress Bar (Dynamic) -->
  <div class="shipping-progress-wrap">
    <div id="shipping-progress-text">Spend $60.00 more for FREE shipping!</div>
    <div class="shipping-progress-bg">
      <div class="shipping-progress-bar" id="shipping-progress-bar" style="width: 0%;"></div>
    </div>
  </div>

  <div class="cart-drawer-header">
    <h3>Shopping Cart (<span id="drawer-cart-count">{{ cart.item_count }}</span>)</h3>
    <button class="cart-drawer-close" id="cart-drawer-close" aria-label="Close cart">&times;</button>
  </div>

  <!-- Cart Items Container -->
  <div class="cart-drawer-items" id="cart-drawer-items">
    <!-- Rendered dynamically by JavaScript -->
    <div class="cart-empty-msg">Your cart is currently empty.</div>
  </div>

  <!-- Drawer Footer (Subtotal, Checkout, Recommendations) -->
  <div class="cart-drawer-footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span id="drawer-cart-subtotal">{{ cart.total_price | money }}</span>
    </div>
    <p class="cart-tax-note">Shipping & taxes calculated at checkout.</p>
    
    <a href="/checkout" class="btn btn-primary btn-checkout">Proceed to Checkout</a>
    <a href="#" class="view-cart-link" id="continue-shopping">Continue Shopping</a>
    
    <!-- Cross-Sells / Upsell Products inside Cart -->
    <div class="cart-drawer-upsell">
      <h4>Frequently Bought Together</h4>
      <div class="cart-upsell-list" id="cart-upsell-list">
        <!-- Javascript will populate custom suggestions -->
      </div>
    </div>
  </div>
</div>
