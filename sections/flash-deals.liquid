{%- assign collection = section.settings.collection -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}
{%- assign end_time = section.settings.end_time -%}

<section class="section" aria-labelledby="flash-deals-title">
  <div class="container">
    <div class="flash-deals__header">
      <div>
        <span class="section-label">Limited Time</span>
        <h2 class="section-title" id="flash-deals-title">{{ section.settings.title | default: "Today's Best Deals" }}</h2>
      </div>

      {%- if end_time != blank -%}
        {%- assign end_timestamp = end_time | date: '%s' | times: 1000 -%}
        <div class="flash-deals__countdown">
          <span class="flash-deals__countdown-label">Ends in</span>
          <div class="countdown-timer" data-countdown="{{ end_timestamp }}" aria-label="Countdown timer">
            <div class="countdown-unit">
              <span class="countdown-unit__value" data-unit="h">--</span>
              <span class="countdown-unit__label">hrs</span>
            </div>
            <span class="countdown-sep" aria-hidden="true">:</span>
            <div class="countdown-unit">
              <span class="countdown-unit__value" data-unit="m">--</span>
              <span class="countdown-unit__label">min</span>
            </div>
            <span class="countdown-sep" aria-hidden="true">:</span>
            <div class="countdown-unit">
              <span class="countdown-unit__value" data-unit="s">--</span>
              <span class="countdown-unit__label">sec</span>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- liquid
      assign deals_list = collection.products
      if deals_list.size == 0 or collection == blank
        # Filter products with compare_at_price > price
        assign deals_list = ""
        for prod in collections.all.products
          if prod.compare_at_price > prod.price
            if deals_list != ""
              assign deals_list = deals_list | append: ","
            endif
            assign deals_list = deals_list | append: prod.id
          endif
        endfor
        assign deal_ids = deals_list | split: ","
      endif
    -%}

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="flash-deals__scroll">
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- elsif deal_ids.size > 0 -%}
      <div class="flash-deals__scroll">
        {%- assign deal_count = 0 -%}
        {%- for product in collections.all.products -%}
          {%- assign prod_id_str = product.id | string -%}
          {%- if deal_ids contains prod_id_str -%}
            {%- render 'product-card', product: product -%}
            {%- assign deal_count = deal_count | plus: 1 -%}
            {%- if deal_count >= products_to_show -%}{%- break -%}{%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="flash-deals__scroll">
        {%- for product in collections.all.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Flash Deals",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Today's Best Deals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Deals collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 2,
      "label": "Number of products",
      "default": 4
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "Deal end date/time",
      "placeholder": "2025-12-31 23:59:59",
      "info": "Format: YYYY-MM-DD HH:MM:SS. Leave empty to hide countdown."
    }
  ],
  "presets": [{ "name": "Flash Deals" }]
}
{% endschema %}
