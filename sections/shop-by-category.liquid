<section class="section section--alt" aria-labelledby="categories-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">{{ section.settings.label | default: 'Browse by Category' }}</span>
        <h2 class="section-title" id="categories-title">{{ section.settings.title | default: 'Everything Your Pet Needs' }}</h2>
      </div>
    </div>

    <div class="category-grid" role="list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign cat_url = block.settings.collection.url | default: block.settings.fallback_url | default: '/collections/all' -%}
          {%- assign cat_image = block.settings.image -%}
          <a href="{{ cat_url }}" class="category-card" role="listitem" {{ block.shopify_attributes }} aria-label="{{ block.settings.name }}">
            <div class="category-card__image-wrapper" aria-hidden="true">
              {%- if cat_image != blank -%}
                <img
                  src="{{ cat_image | image_url: width: 240 }}"
                  alt="{{ block.settings.name | escape }}"
                  class="category-card__img"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              {%- else -%}
                {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/05_Dog_Bowls_web_800x.png?v=1781287504' -%}
                {%- assign name_downcase = block.settings.name | downcase -%}
                {%- if name_downcase contains 'toy' -%}
                  {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/cat_toys_79bf694c-2c5c-4f18-8cac-626ccf76c503.webp?v=1742375228' -%}
                {%- elsif name_downcase contains 'walk' or name_downcase contains 'collar' or name_downcase contains 'leash' or name_downcase contains 'accessories' -%}
                  {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/CLH_for_dogs.webp?v=1742375228' -%}
                {%- elsif name_downcase contains 'chew' or name_downcase contains 'treat' or name_downcase contains 'yakies' -%}
                  {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/Yakies_for_dogs.webp?v=1742375228' -%}
                {%- elsif name_downcase contains 'litter' or name_downcase contains 'cleaning' or name_downcase contains 'grooming' -%}
                  {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/09_Cat_Litter_web_800x.png?v=1781287577' -%}
                {%- elsif name_downcase contains 'broth' or name_downcase contains 'health' or name_downcase contains 'supplement' -%}
                  {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/04_Bone_broth_web_800x.png?v=1781287425' -%}
                {%- elsif name_downcase contains 'food' -%}
                  {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/Saras_Wholesome_Food_e98d8515-7c28-4865-9da1-46527afa9353.webp?v=1742375228' -%}
                {%- elsif name_downcase contains 'dental' -%}
                  {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/03_Ice_Cream_web_800x.png?v=1781287452' -%}
                {%- elsif name_downcase contains 'beds' or name_downcase contains 'sleep' -%}
                  {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/Beds_web_981aac84-1a00-43ea-a49b-c0c913a7a066_800x.webp?v=1783494102' -%}
                {%- elsif name_downcase contains 'travel' -%}
                  {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/02_Grooming_web_800x.png?v=1781287479' -%}
                {%- endif -%}
                <img
                  src="{{ fallback_img }}"
                  alt="{{ block.settings.name | escape }}"
                  class="category-card__img"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              {%- endif -%}
            </div>
            <span class="category-card__name">{{ block.settings.name }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_categories = "Health,Food,Treats,Dental,Travel,Beds,Cleaning,Accessories,Training,Toys" | split: "," -%}
        {%- for cat_name in fallback_categories -%}
          {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/05_Dog_Bowls_web_800x.png?v=1781287504' -%}
          {%- assign name_downcase = cat_name | downcase -%}
          {%- if name_downcase contains 'toy' -%}
            {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/cat_toys_79bf694c-2c5c-4f18-8cac-626ccf76c503.webp?v=1742375228' -%}
          {%- elsif name_downcase contains 'walk' or name_downcase contains 'collar' or name_downcase contains 'leash' or name_downcase contains 'accessories' -%}
            {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/CLH_for_dogs.webp?v=1742375228' -%}
          {%- elsif name_downcase contains 'chew' or name_downcase contains 'treat' or name_downcase contains 'yakies' -%}
            {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/Yakies_for_dogs.webp?v=1742375228' -%}
          {%- elsif name_downcase contains 'litter' or name_downcase contains 'cleaning' or name_downcase contains 'grooming' -%}
            {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/09_Cat_Litter_web_800x.png?v=1781287577' -%}
          {%- elsif name_downcase contains 'broth' or name_downcase contains 'health' or name_downcase contains 'supplement' -%}
            {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/04_Bone_broth_web_800x.png?v=1781287425' -%}
          {%- elsif name_downcase contains 'food' -%}
            {%- assign fallback_img = 'https://cdn.shopify.com/s/files/1/0086/0795/7054/files/Saras_Wholesome_Food_e98d8515-7c28-4865-9da1-46527afa9353.webp?v=1742375228' -%}
          {%- elsif name_downcase contains 'dental' -%}
            {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/03_Ice_Cream_web_800x.png?v=1781287452' -%}
          {%- elsif name_downcase contains 'beds' or name_downcase contains 'sleep' -%}
            {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/Beds_web_981aac84-1a00-43ea-a49b-c0c913a7a066_800x.webp?v=1783494102' -%}
          {%- elsif name_downcase contains 'travel' -%}
            {%- assign fallback_img = 'https://headsupfortails.com/cdn/shop/files/02_Grooming_web_800x.png?v=1781287479' -%}
          {%- endif -%}
          <a href="/collections/all" class="category-card" role="listitem" aria-label="{{ cat_name }}">
            <div class="category-card__image-wrapper" aria-hidden="true">
              <img
                src="{{ fallback_img }}"
                alt="{{ cat_name }}"
                class="category-card__img"
                loading="lazy"
                width="120"
                height="120"
              >
            </div>
            <span class="category-card__name">{{ cat_name }}</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Everything Your Pet Needs"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image (lifestyle or product)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Health"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to collection"
        },
        {
          "type": "url",
          "id": "fallback_url",
          "label": "Fallback URL (if no collection selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "name": "Health" } },
        { "type": "category", "settings": { "name": "Food" } },
        { "type": "category", "settings": { "name": "Treats" } },
        { "type": "category", "settings": { "name": "Dental" } },
        { "type": "category", "settings": { "name": "Travel" } },
        { "type": "category", "settings": { "name": "Beds" } },
        { "type": "category", "settings": { "name": "Cleaning" } },
        { "type": "category", "settings": { "name": "Accessories" } },
        { "type": "category", "settings": { "name": "Training" } },
        { "type": "category", "settings": { "name": "Toys" } }
      ]
    }
  ]
}
{% endschema %}
