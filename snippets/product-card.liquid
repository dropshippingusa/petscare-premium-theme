{% comment %}
  Reusable Shopify Product Card Snippet
{% endcomment %}

<div class="product-card" data-product-id="{{ product.id }}">
  <div class="product-img-wrap">
    <!-- Badges -->
    <div class="product-badges">
      {% if product.compare_at_price > product.price %}
        <span class="badge-tag sale-tag">Sale</span>
      {% endif %}
      {% if product.tags contains 'new' %}
        <span class="badge-tag new-tag">New</span>
      {% endif %}
      {% if product.tags contains 'bestseller' %}
        <span class="badge-tag bestseller">Bestseller</span>
      {% endif %}
    </div>

    <!-- Image -->
    <a href="{{ product.url }}" class="product-img-link">
      {% if product.featured_image != blank %}
        <img class="lazyload" src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title | escape }}">
      {% else %}
        <div class="product-img-placeholder">🐾</div>
      {% endif %}
    </a>

    <!-- Overlay Actions -->
    <div class="product-overlay">
      <button class="quick-add" onclick="ajaxAddToCart('{{ product.selected_or_first_available_variant.id }}')">Quick Add</button>
      <button class="wish-btn" onclick="toggleWishlist('{{ product.id }}')">♡</button>
    </div>
  </div>

  <div class="product-info">
    <p class="product-brand">{{ product.vendor }}</p>
    <h3 class="product-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    
    <!-- Rating -->
    <div class="product-rating">
      <span class="stars">★★★★★</span>
      <span class="rating-val">(4.9)</span>
    </div>

    <!-- Pricing -->
    <div class="product-footer">
      <div class="price-wrap">
        <span class="price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="old-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
      
      <!-- Cart Trigger -->
      <button class="cart-add-btn" onclick="ajaxAddToCart('{{ product.selected_or_first_available_variant.id }}')" aria-label="Add to cart">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </button>
    </div>
  </div>
</div>
