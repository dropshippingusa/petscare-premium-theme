{%- liquid
  assign msg_1 = section.settings.announcement_1 | default: '🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout'
  assign msg_2 = section.settings.announcement_2 | default: 'Free shipping on orders $99+'
  assign msg_3 = section.settings.announcement_3 | default: 'Secure Checkout: Shop with confidence'
  assign msg_4 = section.settings.announcement_4 | default: 'Fast US Shipping: Formulated & Packaged in the USA'
  assign msg_5 = section.settings.announcement_5 | default: 'Hassle-Free Returns: Shop Risk-Free'
-%}

<div class="site-header-wrapper" id="site-header-wrapper">
<div class="announcement-bar" id="announcement-bar-ticker" role="region" aria-label="Announcements">
  <div class="announcement-bar__ticker">
    <div class="announcement-slide is-active" role="group" aria-label="1 of 5">{{ msg_1 }}</div>
    <div class="announcement-slide" role="group" aria-label="2 of 5" style="display: none;">{{ msg_2 }}</div>
    <div class="announcement-slide" role="group" aria-label="3 of 5" style="display: none;">{{ msg_3 }}</div>
    <div class="announcement-slide" role="group" aria-label="4 of 5" style="display: none;">{{ msg_4 }}</div>
    <div class="announcement-slide" role="group" aria-label="5 of 5" style="display: none;">{{ msg_5 }}</div>
  </div>
</div>

<header class="site-header" role="banner">

  <!-- ═══ TOP ROW: Logo | Search | Actions (Location/Login/Wishlist/Cart) ═══ -->
  <div class="header-container">

    <!-- Logo -->
    <a href="/" class="header-logo-container" aria-label="{{ shop.name }} — Home">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--default">
      <img src="{{ 'logo-sticky.png' | asset_url }}" alt="{{ shop.name | escape }}" class="header-logo__img header-logo--sticky" style="display: none;">
    </a>

    <!-- Search Bar with Live Autocomplete -->
    <div class="header-search-wrap" id="header-search-wrap">
      <form action="/search" method="get" class="header-search-form" role="search" autocomplete="off">
        <span class="header-search-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="text"
          name="q"
          id="header-search-input"
          placeholder="Search for Products, Brands and More"
          class="header-search-input"
          aria-label="Search store"
          aria-autocomplete="list"
          aria-controls="search-autocomplete"
          aria-expanded="false"
        >
      </form>
      <!-- Live search dropdown -->
      <div class="search-autocomplete" id="search-autocomplete" role="listbox" hidden>
        <div class="search-autocomplete__inner" id="search-autocomplete-inner"></div>
      </div>
    </div>

    <!-- ★ LOCKED ACTIONS — Never move, never hide ★ -->
    <div class="header-actions">

      <!-- Location -->
      <a href="#" class="header-action-link header-location-icon-btn" id="header-loc-btn" title="Select delivery location" aria-label="Select delivery location">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="loc-zip-inline">90210</span>
      </a>

      <!-- Login / Account -->
      {%- if customer -%}
        <a href="/account" class="header-action-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Account</span>
        </a>
      {%- else -%}
        <a href="/account/login" class="header-action-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Login</span>
        </a>
      {%- endif -%}

      <!-- Wishlist -->
      <a href="/pages/wishlist" class="header-action-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span>Wishlist</span>
      </a>

      <!-- Cart -->
      <button type="button" class="header-action-link header-cart-btn" data-open-cart>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span>Cart</span>
        <span class="cart-count-badge" id="header-cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>

    </div>
  </div>

  <!-- ═══ NAV ROW: constrained to theme width, See More always visible ═══ -->
  <div class="header-nav-row">
    <nav class="header-nav" aria-label="Main navigation">

      <!-- Home -->
      <a href="/" class="header-nav__link{% if request.path == '/' %} is-active{% endif %}">Home</a>

      <!-- Top Picks — highlighted, pinned right after Home -->
      <a href="/collections/top-picks" class="header-nav__link header-nav__link--hot header-nav__coll-link{% if request.path == '/collections/top-picks' %} is-active{% endif %}">
        Top Picks <span class="nav-hot-badge">🔥</span>
      </a>

      <!-- All Products -->
      <a href="/collections/all" class="header-nav__link{% if request.path == '/collections/all' %} is-active{% endif %}">All Products</a>

      <!-- ALL collections rendered (limit:50 to show more than default 20) -->
      <!-- JS hides overflow ones into See More dropdown -->
      {%- for collection in collections limit: 50 -%}
        {%- unless collection.handle == 'frontpage'
          or collection.handle == 'all'
          or collection.handle == 'dogs'
          or collection.handle == 'cats'
          or collection.handle == 'top-picks'
          or collection.title == 'Top Picks' -%}
          <a href="{{ collection.url }}" class="header-nav__link header-nav__coll-link{% if request.path == collection.url %} is-active{% endif %}">{{ collection.title }}</a>
        {%- endunless -%}
      {%- endfor -%}

      <!-- See More: ALWAYS at right end — has dropdown for overflow items -->
      <div class="header-nav__more-wrap">
        <button type="button" class="header-nav__link header-nav__see-more-btn" id="nav-see-more-btn" aria-expanded="false" aria-haspopup="listbox">
          See More <span class="see-more-chevron">▾</span>
        </button>
        <div class="header-nav__more-dropdown" id="nav-see-more-dropdown" hidden role="listbox">
          <!-- overflow links injected here by JS -->
        </div>
      </div>

    </nav>
  </div>

</header>
</div>

<script>
(function() {
  function initNavOverflow() {
    var nav      = document.querySelector('.header-nav');
    var btn      = document.getElementById('nav-see-more-btn');
    var dropdown = document.getElementById('nav-see-more-dropdown');
    if (!nav || !btn || !dropdown) return;

    // All collection links (candidates for overflow)
    var collLinks = Array.from(nav.querySelectorAll('.header-nav__coll-link'));
    var overflowLinks = [];

    function compute() {
      // 1. Reset: show all collection links, clear dropdown
      collLinks.forEach(function(el) { el.hidden = false; });
      dropdown.innerHTML = '';
      dropdown.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.querySelector('.see-more-chevron').textContent = '\u25BE';
      overflowLinks = [];

      // 2. Hide collection links from the right until nav fits
      for (var i = collLinks.length - 1; i >= 0; i--) {
        if (nav.scrollWidth <= nav.clientWidth) break;
        collLinks[i].hidden = true;
        overflowLinks.unshift(collLinks[i]);
      }

      // 3. Build dropdown links from overflow items
      overflowLinks.forEach(function(el) {
        var a = document.createElement('a');
        a.href = el.href;
        a.textContent = el.textContent.trim();
        a.className = 'header-nav__more-drop-item';
        dropdown.appendChild(a);
      });
    }

    // Toggle dropdown on See More click
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (overflowLinks.length === 0) return; // nothing to show
      var isOpen = !dropdown.hidden;
      dropdown.hidden = isOpen;
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      btn.querySelector('.see-more-chevron').textContent = isOpen ? '\u25BE' : '\u25B4';
    });

    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      if (!btn.parentElement.contains(e.target)) {
        dropdown.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.see-more-chevron').textContent = '\u25BE';
      }
    });

    // Debounced resize
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(compute, 120);
    });

    // Delay so fonts finish rendering before we measure
    setTimeout(compute, 80);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavOverflow);
  } else {
    initNavOverflow();
  }
})();
</script>

<script>
/* ── Live Search Autocomplete ─────────────────────── */
(function() {
  var input     = document.getElementById('header-search-input');
  var dropdown  = document.getElementById('search-autocomplete');
  var inner     = document.getElementById('search-autocomplete-inner');
  if (!input || !dropdown || !inner) return;

  var debounceTimer;
  var lastQuery = '';

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function showDropdown(products) {
    if (!products || products.length === 0) {
      inner.innerHTML = '<p class="search-autocomplete__empty">No products found</p>';
    } else {
      inner.innerHTML = products.map(function(p) {
        var img = p.featured_image
          ? '<img src="' + p.featured_image.url + '" alt="' + p.featured_image.alt + '" class="search-autocomplete__img" loading="lazy">'
          : '<div class="search-autocomplete__img search-autocomplete__img--placeholder"></div>';
        var price = p.price ? formatMoney(p.price) : '';
        var comparePrice = (p.compare_at_price && p.compare_at_price > p.price)
          ? '<s class="search-autocomplete__compare">' + formatMoney(p.compare_at_price) + '</s>' : '';
        return '<a href="' + p.url + '" class="search-autocomplete__item" role="option">'
          + img
          + '<span class="search-autocomplete__info">'
          +   '<span class="search-autocomplete__title">' + p.title + '</span>'
          +   '<span class="search-autocomplete__price">' + price + ' ' + comparePrice + '</span>'
          + '</span>'
          + '</a>';
      }).join('');
    }
    dropdown.hidden = false;
    input.setAttribute('aria-expanded', 'true');
  }

  function hideDropdown() {
    dropdown.hidden = true;
    input.setAttribute('aria-expanded', 'false');
    inner.innerHTML = '';
    lastQuery = '';
  }

  function fetchSuggestions(q) {
    if (q === lastQuery) return;
    lastQuery = q;
    fetch('/search/suggest.json?q=' + encodeURIComponent(q)
      + '&resources[type]=product&resources[limit]=6&resources[options][unavailable_products]=last')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var products = data.resources && data.resources.results && data.resources.results.products;
        showDropdown(products || []);
      })
      .catch(function() { hideDropdown(); });
  }

  input.addEventListener('input', function() {
    var q = this.value.trim();
    clearTimeout(debounceTimer);
    if (q.length < 3) { hideDropdown(); return; }
    debounceTimer = setTimeout(function() { fetchSuggestions(q); }, 250);
  });

  // Close on Escape
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { hideDropdown(); this.blur(); }
  });

  // Close when clicking outside
  document.addEventListener('click', function(e) {
    if (!document.getElementById('header-search-wrap').contains(e.target)) {
      hideDropdown();
    }
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Ticker"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Message 1",
      "default": "🐾 New Customers: Enjoy 10% OFF Your First Order • Use Code: WELCOME10 at Checkout"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Message 2",
      "default": "Free shipping on orders $99+"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Message 3",
      "default": "Secure Checkout: Shop with confidence"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Message 4",
      "default": "Fast US Shipping: Formulated & Packaged in the USA"
    },
    {
      "type": "text",
      "id": "announcement_5",
      "label": "Message 5",
      "default": "Hassle-Free Returns: Shop Risk-Free"
    }
  ]
}
{% endschema %}
