<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'seo-schema' %}

  <!-- Fonts: Rubik (Heads Up For Tails Style) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Preload Rubik font to prevent FOIT on mobile -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet"></noscript>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
    <!-- Meta Pixel Code -->
  <script>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '968526032884488');
  fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=968526032884488&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->
</head>
<body class="template-{{ template.name }}">

  {% section 'header' %}

  <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- comment -%} Cart Drawer — rendered via AJAX, no app needed {%- endcomment -%}
  <div id="cart-drawer" class="cart-drawer" aria-hidden="true" role="dialog" aria-label="Shopping cart">
    <div class="cart-drawer__overlay" onclick="PetsCare.cart.close()"></div>
    <div class="cart-drawer__panel">
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">My Cart <span id="cart-count-label">({{ cart.item_count }})</span></h2>
        <button class="icon-btn" onclick="PetsCare.cart.close()" aria-label="Close cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      {%- comment -%} Free shipping progress bar {%- endcomment -%}
      <div class="shipping-bar" id="shipping-bar">
        {%- assign threshold = 9900 -%}
        {%- if cart.total_price >= threshold -%}
          <p class="shipping-bar__text shipping-bar__text--done">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            You've unlocked <strong>FREE shipping!</strong>
          </p>
        {%- else -%}
          {%- assign remaining_cents = threshold | minus: cart.total_price -%}
          <p class="shipping-bar__text">Add <strong>{{ remaining_cents | money }}</strong> more for FREE shipping</p>
          <div class="shipping-bar__track">
            {%- assign pct = cart.total_price | times: 100 | divided_by: threshold -%}
            <div class="shipping-bar__fill" style="width: {{ pct }}%"></div>
          </div>
        {%- endif -%}
      </div>
      {%- comment -%} Cart line items — re-rendered via JS after mutations {%- endcomment -%}
      <div id="cart-drawer-lines" class="cart-drawer__lines">
        {%- render 'cart-line-items', cart: cart -%}
      </div>
      <div class="cart-drawer__footer" id="cart-drawer-footer" {% if cart.item_count == 0 %}hidden{% endif %}>
        {%- assign total_savings = 0 -%}
        {%- for item in cart.items -%}
          {%- if item.variant.compare_at_price > item.variant.price -%}
            {%- assign savings_diff = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity -%}
            {%- assign total_savings = total_savings | plus: savings_diff -%}
          {%- endif -%}
        {%- endfor -%}
        
        <div class="cart-subtotal">
          <span class="cart-subtotal__label">Subtotal</span>
          <span class="cart-subtotal__amount" id="cart-subtotal-amount">{{ cart.total_price | money }}</span>
        </div>
        
        {%- if total_savings > 0 -%}
          <div class="cart-savings-row" id="cart-drawer-savings-row">
            <span class="cart-savings__label">🎉 Total Savings</span>
            <span class="cart-savings__amount" id="cart-drawer-savings-amount">-{{ total_savings | money }}</span>
          </div>
        {%- endif -%}
        
        <p class="cart-drawer__tax-note">Taxes and shipping calculated at checkout</p>
        <a href="/checkout" class="btn btn--primary btn--full btn--lg">Checkout</a>
        <a href="/cart" class="btn btn--ghost btn--full">View full cart</a>
      </div>
    </div>
  </div>

  {%- comment -%} Search overlay — uses /search/suggest.json (Shopify native) {%- endcomment -%}
  <div id="search-overlay" class="search-overlay" aria-hidden="true" role="dialog" aria-label="Search">
    <div class="search-overlay__backdrop" onclick="PetsCare.search.close()"></div>
    <div class="search-overlay__box">
      <form action="/search" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-overlay__field">
          <svg class="search-overlay__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="search" name="q" id="search-input" class="search-overlay__input" placeholder="Search products, brands, ingredients…" autocomplete="off" aria-label="Search products">
          <button type="button" class="icon-btn" onclick="PetsCare.search.close()" aria-label="Close search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </form>
      <div id="search-results" class="search-results" aria-live="polite"></div>
    </div>
  </div>

  {%- comment -%} Mobile bottom navigation (SVG icons only, no emojis) {%- endcomment -%}
  <nav class="mobile-bottom-nav" aria-label="Bottom navigation">
    <a href="/" class="mobile-nav-item {% if template.name == 'index' %}is-active{% endif %}" aria-label="Home">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Home</span>
    </a>
    <a href="/collections/all" class="mobile-nav-item {% if template.name == 'collection' %}is-active{% endif %}" aria-label="Shop all">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span>Shop</span>
    </a>
    <button type="button" class="mobile-nav-item" onclick="PetsCare.search.open()" aria-label="Search">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>Search</span>
    </button>
    <button type="button" class="mobile-nav-item mobile-nav-cart" onclick="PetsCare.cart.open()" aria-label="Open cart">
      <span class="mobile-nav-cart__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="mobile-cart-badge" id="mobile-cart-badge" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </span>
      <span>Cart</span>
    </button>
    <a href="/account" class="mobile-nav-item {% if template.name contains 'customers' %}is-active{% endif %}" aria-label="Account">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Account</span>
    </a>
  </nav>

  {%- comment -%} Add-to-cart toast notification {%- endcomment -%}
  <div id="cart-toast" class="cart-toast" role="status" aria-live="polite" aria-atomic="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <span id="cart-toast-msg">Added to cart!</span>
  </div>

  {%- if customer and customer.orders.size > 0 -%}
    {%- assign last_order = customer.orders.first -%}
    {%- assign last_item = last_order.line_items.first -%}
    <div id="recent-purchase-toast" class="recent-purchase-toast" aria-live="polite">
      {%- if last_item.image -%}
        <img src="{{ last_item.image | image_url: width: 120 }}" alt="{{ last_item.title }}" class="recent-purchase-toast__img" loading="lazy">
      {%- endif -%}
      <div>
        <p class="recent-purchase-toast__title">You recently purchased</p>
        <a href="{{ last_item.url }}" class="recent-purchase-toast__link">{{ last_item.title | truncate: 36 }}</a>
        <p class="recent-purchase-toast__date">Ordered {{ last_order.created_at | date: "%b %d, %Y" }}</p>
      </div>
    </div>
  {%- endif -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>

