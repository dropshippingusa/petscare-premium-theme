{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: product.id
  assign media_count = product.media.size
-%}

{%- comment -%} Breadcrumb {%- endcomment -%}
<nav class="breadcrumb-nav" aria-label="Breadcrumb">
  <div class="container">
    <ol class="breadcrumb" role="list">
      <li class="breadcrumb__item"><a href="/">Home</a></li>
      <li class="breadcrumb__item breadcrumb__sep" aria-hidden="true">/</li>
      {%- if product.collections.first -%}
        <li class="breadcrumb__item"><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
        <li class="breadcrumb__item breadcrumb__sep" aria-hidden="true">/</li>
      {%- endif -%}
      <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ product.title | truncate: 40 }}</li>
    </ol>
  </div>
</nav>

{%- comment -%} Main PDP Layout {%- endcomment -%}
{%- form 'product', product, id: product_form_id, class: 'pdp-layout container pdp-form-layout', novalidate: 'novalidate' -%}
  <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">

  {%- comment -%} ── LEFT COLUMN: Gallery ─────────────────────────────────── {%- endcomment -%}
  <div class="pdp-gallery" id="pdp-gallery">
    
    <div class="pdp-gallery__images">
      {%- comment -%} Main image {%- endcomment -%}
      <div class="pdp-gallery__main" id="pdp-main-media" role="img" aria-label="{{ product.featured_media.alt | default: product.title | escape }}">
        {%- if product.featured_media != blank -%}
          {%- if product.featured_media.media_type == 'video' -%}
            {{- product.featured_media | video_tag: autoplay: false, loop: false, controls: true, class: 'pdp-gallery__main-img', preload: 'none' -}}
          {%- elsif product.featured_media.media_type == 'external_video' -%}
            {{- product.featured_media | external_video_tag: class: 'pdp-gallery__main-img' -}}
          {%- elsif product.featured_media.media_type == 'model' -%}
            <div class="pdp-gallery__main-img" style="display:flex;align-items:center;justify-content:center;background:var(--bg-subtle);">
              {{- product.featured_media | model_viewer_tag -}}
            </div>
          {%- else -%}
            <img
              id="pdp-main-img"
              src="{{ product.featured_media | image_url: width: 1000 }}"
              srcset="{{ product.featured_media | image_url: width: 600 }} 600w, {{ product.featured_media | image_url: width: 1000 }} 1000w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ product.featured_media.alt | default: product.title | escape }}"
              class="pdp-gallery__main-img"
              loading="eager"
              fetchpriority="high"
              width="1000" height="1000"
            >
          {%- endif -%}
        {%- else -%}
          <div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--bg-subtle);">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Thumbnail strip — Shopify product.media object {%- endcomment -%}
      {%- if media_count > 1 -%}
        <div class="pdp-gallery__thumbs" role="list" aria-label="Product images">
          {%- for media in product.media -%}
            {%- assign show_overlay = false -%}
            {%- assign is_hidden = false -%}
            
            {%- if media_count > 5 -%}
              {%- if forloop.index == 5 -%}
                {%- assign show_overlay = true -%}
              {%- elsif forloop.index > 5 -%}
                {%- assign is_hidden = true -%}
              {%- endif -%}
            {%- endif -%}

            <button
              type="button"
              class="pdp-thumb {% if forloop.first %}is-active{% endif %} {% if is_hidden %}pdp-thumb--hidden{% endif %} {% if show_overlay %}pdp-thumb--more{% endif %}"
              data-src="{{ media | image_url: width: 1000 }}"
              data-media-id="{{ media.id }}"
              aria-label="{{ media.alt | default: product.title | escape }}, image {{ forloop.index }}"
              role="listitem"
            >
              {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                <span class="pdp-thumb__video-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="white" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </span>
              {%- endif -%}
              <img
                src="{{ media | image_url: width: 144 }}"
                alt="{{ media.alt | default: product.title | escape }}"
                width="72" height="72"
                loading="lazy"
              >
              {%- if show_overlay -%}
                <span class="pdp-thumb__overlay">+{{ media_count | minus: 4 }}</span>
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Buy Box Row for Desktop (underneath image) -->
    <div class="pdp-gallery__atc pdp-desktop-only" style="margin-top:20px; width:100%;">
      <div class="pdp-atc-row">
        <button
          type="submit"
          name="add"
          id="pdp-atc-btn-desktop"
          class="btn btn--add-to-cart"
          {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
        >
          {%- if current_variant.available -%}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
            Add to Cart
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
        <button
          type="button"
          class="btn btn--buy-now pdp-buy-now-btn"
          {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
        >
          {%- if current_variant.available -%}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span class="buy-now-label">Buy at {{ current_variant.price | money }}</span>
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
        <button
          type="button"
          class="btn btn--wishlist"
          data-wishlist-toggle="{{ product.id }}"
          aria-label="Add to wishlist"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </button>
      </div>
    </div>

  </div>

  {%- comment -%} ── RIGHT COLUMN: Product Info ───────────────────────────── {%- endcomment -%}
  <div class="pdp-info" id="pdp-info">

    {%- comment -%} Brand / Vendor {%- endcomment -%}
    {%- if product.vendor != blank -%}
      <a href="/collections/vendors?q={{ product.vendor | url_encode }}" class="pdp-brand">{{ product.vendor }}</a>
    {%- endif -%}

    {%- comment -%} Title {%- endcomment -%}
    <h1 class="pdp-title">{{ product.title }}</h1>

    {%- comment -%} Ratings — shows only if Judge.me / Okendo inject metafields {%- endcomment -%}
    {%- if product.metafields.reviews.rating.value != blank -%}
      {%- assign rating_val = product.metafields.reviews.rating.value -%}
      {%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}
      <div class="pdp-rating">
        <span class="pdp-stars" aria-label="{{ rating_val | round: 1 }} out of 5 stars">
          {%- for i in (1..5) -%}★{%- endfor -%}
        </span>
        <span class="pdp-rating__score">{{ rating_val | round: 1 }}</span>
        <a href="#reviews" class="pdp-review-count">({{ rating_count }} reviews)</a>
      </div>
    {%- endif -%}

    {%- comment -%} Price {%- endcomment -%}
    <div class="pdp-price-row" id="pdp-price-row">
      <span class="pdp-price" id="pdp-price">
        {%- if product.price_varies -%}
          From {{ product.price_min | money }}
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="pdp-compare" id="pdp-compare">{{ current_variant.compare_at_price | money }}</span>
        {%- assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price | round -%}
        <span class="badge badge--primary" id="pdp-discount">-{{ discount_pct }}%</span>
      {%- endif -%}
    </div>

    {%- comment -%} Delivery estimate & Free Shipping Progress Bar {%- endcomment -%}
    <div class="pdp-delivery-box">
      <div class="pdp-delivery">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <div>
          {%- if current_variant.available -%}
            <p class="pdp-delivery__status"><strong style="color:var(--green)">In Stock</strong> · Vet Approved · Fast US Delivery</p>
            <p class="pdp-delivery__estimator" id="pdp-delivery-estimator" data-price="{{ current_variant.price }}">Estimating delivery date...</p>
          {%- else -%}
            <strong style="color:var(--red)">Currently unavailable</strong>
          {%- endif -%}
        </div>
      </div>
      
      {%- if current_variant.available -%}
        <div class="pdp-shipping-bar" id="pdp-shipping-bar">
          {%- assign threshold = 4900 -%}
          {%- assign price = current_variant.price -%}
          {%- if price >= threshold -%}
            <p class="pdp-shipping-bar__text">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;color:var(--green)"><polyline points="20 6 9 17 4 12"/></svg>
              This item qualifies for <strong>FREE shipping!</strong>
            </p>
          {%- else -%}
            {%- assign remaining = threshold | minus: price -%}
            <p class="pdp-shipping-bar__text">Add <strong>{{ remaining | money }}</strong> more to unlock FREE shipping</p>
            <div class="pdp-shipping-bar__track">
              {%- assign pct = price | times: 100 | divided_by: threshold -%}
              <div class="pdp-shipping-bar__fill" id="pdp-shipping-bar-fill" style="width: {{ pct }}%"></div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product Form {%- endcomment -%}
    {%- form 'product', product, id: product_form_id, class: 'pdp-form', novalidate: 'novalidate' -%}

      <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">

      {%- comment -%} Variant selectors — pills for each option {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="variant-group">
            <p class="variant-group__label">
              {{ option.name }}:
              <span id="selected-{{ option.position }}">{{ option.selected_value }}</span>
            </p>
            <div class="variant-pills" role="group" aria-label="{{ option.name }} options">
              {%- for value in option.values -%}
                {%- comment -%} Check if this option value leads to an available variant {%- endcomment -%}
                {%- assign variant_available = false -%}
                {%- for variant in product.variants -%}
                  {%- assign opt_pos = option.position | minus: 1 -%}
                  {%- if variant.options[opt_pos] == value and variant.available -%}
                    {%- assign variant_available = true -%}
                  {%- endif -%}
                {%- endfor -%}
                <button
                  type="button"
                  class="variant-pill {% if option.selected_value == value %}is-selected{% endif %} {% unless variant_available %}is-unavailable{% endunless %}"
                  data-option-position="{{ option.position }}"
                  data-value="{{ value | escape }}"
                  {% unless variant_available %}aria-disabled="true"{% endunless %}
                  aria-label="{{ option.name }}: {{ value }}"
                >
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} Quantity {%- endcomment -%}
      <div class="pdp-qty-row">
        <label for="pdp-qty" class="sr-only">Quantity</label>
        <div class="qty-control" role="group" aria-label="Product quantity">
          <button type="button" class="qty-btn" data-qty-change="-1" aria-label="Decrease quantity">−</button>
          <input
            type="number"
            id="pdp-qty"
            name="quantity"
            class="qty-input"
            value="1"
            min="1"
            aria-label="Quantity"
          >
          <button type="button" class="qty-btn" data-qty-change="1" aria-label="Increase quantity">+</button>
        </div>
      </div>

      <!-- Buy Box Row for Mobile (underneath variants in right column) -->
      <div class="pdp-info__atc pdp-mobile-only" style="margin-top:20px;">
        <div class="pdp-atc-row">
          <button
            type="submit"
            name="add"
            id="pdp-atc-btn-mobile"
            class="btn btn--add-to-cart"
            {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
          >
            {%- if current_variant.available -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
          <button
            type="button"
            class="btn btn--buy-now pdp-buy-now-btn"
            {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
          >
            {%- if current_variant.available -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <span class="buy-now-label">Buy at {{ current_variant.price | money }}</span>
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
          <button
            type="button"
            class="btn btn--wishlist"
            data-wishlist-toggle="{{ product.id }}"
            aria-label="Add to wishlist"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </button>
        </div>
      </div>

      {%- comment -%} Trust row {%- endcomment -%}
      <div class="pdp-trust" role="list" style="margin-top: 24px;">
        <div class="pdp-trust-item" role="listitem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Free Shipping $49+
        </div>
        <div class="pdp-trust-item" role="listitem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          Easy Returns
        </div>
        <div class="pdp-trust-item" role="listitem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Vet Approved
        </div>
        <div class="pdp-trust-item" role="listitem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 8C8 10 5.9 16.17 3.82 19.47a1 1 0 001.74 1c.6-1.05 1.33-2.05 2.2-2.92C9 19.5 11 20 13 20c4 0 8-3 9-9-1 1-2 2-5 2s-5-2-5-2c3 0 5-1 5-3z"/></svg>
          Natural Ingredients
        </div>
      </div>

      {%- comment -%} Product Info Tabs inside Right Column {%- endcomment -%}
      <div class="pdp-tabs" style="margin-top: 30px;">
        <div class="pdp-tabs__nav" role="tablist">
          <button type="button" class="pdp-tab-btn is-active" role="tab" aria-selected="true" data-tab="tab-description" id="tab-btn-description">Description</button>
          {%- if product.metafields.custom.ingredients != blank -%}
            <button type="button" class="pdp-tab-btn" role="tab" aria-selected="false" data-tab="tab-ingredients" id="tab-btn-ingredients">Ingredients</button>
          {%- endif -%}
          {%- if product.metafields.custom.directions != blank -%}
            <button type="button" class="pdp-tab-btn" role="tab" aria-selected="false" data-tab="tab-directions" id="tab-btn-directions">Directions</button>
          {%- endif -%}
          {%- if product.metafields.custom.specifications != blank -%}
            <button type="button" class="pdp-tab-btn" role="tab" aria-selected="false" data-tab="tab-specs" id="tab-btn-specs">Specifications</button>
          {%- endif -%}
          {%- if product.metafields.custom.faqs != blank -%}
            <button type="button" class="pdp-tab-btn" role="tab" aria-selected="false" data-tab="tab-faqs" id="tab-btn-faqs">FAQs</button>
          {%- endif -%}
          {%- if product.metafields.reviews.rating.value != blank -%}
            <button type="button" class="pdp-tab-btn" role="tab" aria-selected="false" data-tab="tab-reviews" id="tab-btn-reviews">Reviews</button>
          {%- endif -%}
        </div>

        {%- comment -%} Description tab {%- endcomment -%}
        <div id="tab-description" class="pdp-tab-panel is-active" role="tabpanel" aria-labelledby="tab-btn-description">
          {%- if product.description != blank -%}
            <div class="pdp-description-wrapper" id="pdp-desc-wrapper">
              <div class="rte" id="pdp-desc-content">{{ product.description }}</div>
              <div class="pdp-description-fade" id="pdp-desc-fade"></div>
            </div>
            <button type="button" class="btn-see-more" id="pdp-desc-toggle" style="display: none;">
              See More
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          {%- else -%}
            <p class="text-muted">No description available for this product.</p>
          {%- endif -%}
        </div>

        {%- comment -%} Ingredients tab {%- endcomment -%}
        {%- if product.metafields.custom.ingredients != blank -%}
          <div id="tab-ingredients" class="pdp-tab-panel" role="tabpanel" aria-labelledby="tab-btn-ingredients" hidden>
            <div class="rte">{{ product.metafields.custom.ingredients.value }}</div>
          </div>
        {%- endif -%}

        {%- comment -%} Directions tab {%- endcomment -%}
        {%- if product.metafields.custom.directions != blank -%}
          <div id="tab-directions" class="pdp-tab-panel" role="tabpanel" aria-labelledby="tab-btn-directions" hidden>
            <div class="rte">{{ product.metafields.custom.directions.value }}</div>
          </div>
        {%- endif -%}

        {%- comment -%} Specifications tab {%- endcomment -%}
        {%- if product.metafields.custom.specifications != blank -%}
          <div id="tab-specs" class="pdp-tab-panel" role="tabpanel" aria-labelledby="tab-btn-specs" hidden>
            <div class="rte">{{ product.metafields.custom.specifications.value }}</div>
          </div>
        {%- endif -%}

        {%- comment -%} FAQs tab {%- endcomment -%}
        {%- if product.metafields.custom.faqs != blank -%}
          <div id="tab-faqs" class="pdp-tab-panel" role="tabpanel" aria-labelledby="tab-btn-faqs" hidden>
            <div class="rte">{{ product.metafields.custom.faqs.value }}</div>
          </div>
        {%- endif -%}

        {%- comment -%} Reviews tab {%- endcomment -%}
        {%- if product.metafields.reviews.rating.value != blank -%}
          <div id="tab-reviews" class="pdp-tab-panel" role="tabpanel" aria-labelledby="tab-btn-reviews" hidden>
            <div id="reviews">
              {% render 'judge-me-review-widget', context: product %}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Reviews App Embed Hooks {%- endcomment -%}
      <div class="pdp-universal-reviews" style="margin-top:var(--sp-4);">
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}"></div>
        <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
        <div class="stamped-main-widget" id="stamped-main-widget" data-product-id="{{ product.id }}" data-name="{{ product.title | escape }}" data-url="{{ shop.url }}{{ product.url }}" data-image-url="{{ product.featured_image | image_url: width: 120 }}" data-description="{{ product.description | escape }}"></div>
        <div class="yotpo yotpo-main-widget" data-product-id="{{ product.id }}" data-name="{{ product.title | escape }}" data-url="{{ shop.url }}{{ product.url }}" data-image-url="{{ product.featured_image | image_url: width: 120 }}" data-description="{{ product.description | escape }}"></div>
      </div>

    </div>
  {%- endform -%}

{%- comment -%} ── STICKY ADD TO BAG BAR (appears on scroll past main ATC) ── {%- endcomment -%}
<div class="pdp-sticky-atc" id="pdp-sticky-atc" aria-hidden="true">
  <div class="pdp-sticky-atc__inner container">
    <div class="pdp-sticky-atc__product">
      {%- if product.featured_media != blank -%}
        <img src="{{ product.featured_media | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="44" height="44" class="pdp-sticky-atc__img">
      {%- endif -%}
      <div>
        <p class="pdp-sticky-atc__title">{{ product.title | truncate: 50 }}</p>
        <p class="pdp-sticky-atc__price" id="pdp-sticky-price">{{ current_variant.price | money }}</p>
      </div>
    </div>
    <button
      type="button"
      class="btn btn--primary"
      onclick="document.getElementById('{{ product_form_id }}').requestSubmit()"
      {% unless current_variant.available %}disabled{% endunless %}
    >
      {%- if current_variant.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
    </button>
  </div>
</div>

{%- comment -%} ── FREQUENTLY BOUGHT TOGETHER ─────────────────────────────── {%- endcomment -%}
{%- if section.settings.fbt_collection != blank -%}
  {%- assign fbt_collection = collections[section.settings.fbt_collection] -%}
  {%- assign fbt_products = fbt_collection.products | where: 'available', true -%}
  {%- if fbt_products.size > 0 -%}
    <div class="container" style="padding-bottom: var(--sp-6);">
      <div class="fbt-box">
        <div class="fbt-box__header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Frequently Bought Together
        </div>
        <form id="fbt-form">
          {%- comment -%} Current product (always checked, disabled) {%- endcomment -%}
          <div class="fbt-item">
            <input type="checkbox" class="fbt-item__check" checked disabled data-price="{{ current_variant.price }}" data-variant-id="{{ current_variant.id }}" aria-label="{{ product.title | escape }}">
            {%- if product.featured_media -%}
              <img src="{{ product.featured_media | image_url: width: 120 }}" alt="{{ product.title | escape }}" width="60" height="60" class="fbt-item__img" loading="lazy">
            {%- endif -%}
            <div class="fbt-item__info">
              <p class="fbt-item__title">{{ product.title | truncate: 60 }}</p>
              <p class="fbt-item__price">{{ current_variant.price | money }}</p>
            </div>
          </div>
          {%- comment -%} FBT products from collection (up to 3) {%- endcomment -%}
          {%- for fbt_product in fbt_products limit: 3 -%}
            {%- unless fbt_product.id == product.id -%}
              {%- assign fbt_variant = fbt_product.first_available_variant -%}
              <div class="fbt-item">
                <input
                  type="checkbox"
                  class="fbt-item__check"
                  checked
                  data-price="{{ fbt_variant.price }}"
                  data-variant-id="{{ fbt_variant.id }}"
                  aria-label="{{ fbt_product.title | escape }}"
                >
                {%- if fbt_product.featured_media -%}
                  <img src="{{ fbt_product.featured_media | image_url: width: 120 }}" alt="{{ fbt_product.title | escape }}" width="60" height="60" class="fbt-item__img" loading="lazy">
                {%- endif -%}
                <div class="fbt-item__info">
                  <a href="{{ fbt_product.url }}" class="fbt-item__title">{{ fbt_product.title | truncate: 60 }}</a>
                  <p class="fbt-item__price">{{ fbt_variant.price | money }}</p>
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
          <div class="fbt-box__footer">
            <p class="fbt-total">Total: <span id="fbt-total">{{ current_variant.price | money }}</span></p>
            <button type="submit" class="btn btn--primary">
              Add Bundle to Bag
            </button>
          </div>
        </form>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

{%- comment -%} ── RELATED PRODUCTS ──────────────────────────────────────── {%- endcomment -%}
{%- if product.collections.first != blank -%}
  {%- assign related_collection = product.collections.first -%}
  {%- assign related_products = related_collection.products | where: 'available', true -%}
  {%- if related_products.size > 1 -%}
    <section class="section section--alt" aria-labelledby="related-title">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="section-label">You May Also Like</span>
            <h2 class="section-title" id="related-title">More from {{ related_collection.title }}</h2>
          </div>
          <a href="{{ related_collection.url }}" class="view-all-link">
            View all
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="product-grid">
          {%- for related in related_products limit: 4 -%}
            {%- unless related.id == product.id -%}
              {%- render 'product-card', product: related -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{%- comment -%} ── PDP GALLERY LIGHTBOX MODAL ───────────────────────────── {%- endcomment -%}
<div id="pdp-gallery-modal" class="pdp-modal pdp-gallery-modal" aria-hidden="true" role="dialog" aria-label="Product Image Gallery Modal">
  <button type="button" class="pdp-gallery-modal__close" id="pdp-gallery-modal-close" aria-label="Close gallery">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  
  <div class="pdp-gallery-modal__container">
    <div class="pdp-gallery-modal__slider">
      <button type="button" class="pdp-gallery-modal__arrow pdp-gallery-modal__prev" id="pdp-gallery-modal-prev" aria-label="Previous image">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      
      <div class="pdp-gallery-modal__main-image-wrap">
        <img id="pdp-gallery-modal-img" src="{{ product.featured_media | image_url: width: 1200 }}" alt="{{ product.title | escape }}" loading="lazy">
      </div>
      
      <button type="button" class="pdp-gallery-modal__arrow pdp-gallery-modal__next" id="pdp-gallery-modal-next" aria-label="Next image">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    
    <div class="pdp-gallery-modal__thumbs-wrap">
      <div class="pdp-gallery-modal__thumbs" role="list" aria-label="Gallery thumbnails">
        {%- for media in product.media -%}
          <button
            type="button"
            class="pdp-gallery-modal__thumb {% if forloop.first %}is-active{% endif %}"
            data-src="{{ media | image_url: width: 1200 }}"
            data-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
            role="listitem"
          >
            <img src="{{ media | image_url: width: 144 }}" alt="{{ media.alt | default: product.title | escape }}" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{%- comment -%} ── PRODUCT VARIANT JS DATA ───────────────────────────────── {%- endcomment -%}
<script>
  window.PetsCareProductData = {
    id: {{ product.id }},
    variants: {{ product.variants | json }},
    options: {{ product.options_with_values | json }},
    currentVariantId: {{ current_variant.id }}
  };
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "collection",
      "id": "fbt_collection",
      "label": "Frequently Bought Together collection",
      "info": "Products from this collection will appear in the FBT bundle widget below the main product"
    }
  ]
}
{% endschema %}
